@model List<EC.Models.OrderDetailViewModel>

@{
    ViewData["Title"] = "Order Details";
    Layout = "_Layout";
}

<style>
    body {
        background: #f5f5f5;
    }

    .order-container {
        max-width: 1150px;
        margin: auto;
        padding: 25px;
    }

    .order-header {
        background: #fff;
        padding: 20px;
        border-radius: 10px;
        border: 1px solid #e6e6e6;
        margin-bottom: 20px;
    }

    .order-title {
        font-weight: 700;
        color: #0F1111;
    }

    .status-badge {
        background: #e6f4ea;
        color: #1e7e34;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .summary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .info-card {
        background: #fff;
        padding: 20px;
        border-radius: 10px;
        border: 1px solid #e6e6e6;
    }

        .info-card h5 {
            font-weight: 600;
            margin-bottom: 15px;
            border-bottom: 1px solid #eee;
            padding-bottom: 8px;
        }

    .product-card {
        background: #fff;
        border-radius: 10px;
        border: 1px solid #e6e6e6;
        padding: 18px;
        margin-bottom: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .product-left {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .product-img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    .product-name {
        font-weight: 600;
        font-size: 16px;
    }

    .product-info {
        font-size: 13px;
        color: #555;
    }

    .price {
        font-weight: 700;
        font-size: 18px;
        color: #B12704;
    }

    .timeline {
        margin-top: 20px;
        background: #fff;
        border-radius: 10px;
        border: 1px solid #e6e6e6;
        padding: 20px;
    }

    .timeline-step {
        display: flex;
        align-items: center;
        margin-bottom: 12px;
    }

        .timeline-step i {
            margin-right: 10px;
            color: #28a745;
        }
</style>


<div class="order-container">

    <!-- ORDER HEADER -->
    <div class="order-header d-flex justify-content-between align-items-center">

        <h3 class="order-title">
            <i class="bi bi-box-seam"></i> Order Details
        </h3>

        <span class="status-badge">
            Order Placed
        </span>

    </div>


    <!-- SUMMARY -->
    <div class="summary-grid">

        <div class="info-card">

            <h5>Order Summary</h5>

            @{
                decimal total = 0;
            }

            @foreach (var item in Model)
            {
                total += item.Price * item.Quantity;
            }

            <p><strong>Total Items:</strong> @Model.Count</p>
            <p><strong>Total Amount:</strong> ₹@total</p>
            <p><strong>Order Date:</strong> @DateTime.Now.ToString("dd MMM yyyy")</p>

        </div>


        <div class="info-card">

            @{
                var order = Model.FirstOrDefault();
            }
                
            <p><strong>Name:</strong> @order?.UserName</p>
            <p><strong>Phone:</strong> +91 @order?.Phone</p>
            <p><strong>Address:</strong> @order?.Address</p>

        </div>

    </div>


    <!-- PAYMENT -->
    <div class="info-card mb-3">

        <h5>Payment Method</h5>

        <p>
            <i class="bi bi-credit-card"></i>
            Cash on Delivery (COD)
        </p>

    </div>


    <!-- PRODUCT LIST -->
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="product-card">

                <div class="product-left">

                    <img src="/product-images/@item.ProductImage" class="product-img" />

                    <div>

                        <div class="product-name">
                            @item.ProductName
                        </div>

                        <div class="product-info">
                            Quantity: <strong>@item.Quantity</strong>
                        </div>

                        <div class="product-info">
                            Price: ₹@item.Price
                        </div>

                    </div>

                </div>

                <div class="price">
                    ₹@(item.Price* item.Quantity)
                </div>

            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            No products found in this order.
        </div>
    }


    <!-- ORDER STATUS -->

    <div class="timeline">

        <h5>Order Status</h5>

        <div class="timeline-step">
            <i class="bi bi-check-circle-fill"></i> Order Placed
        </div>

        <div class="timeline-step">
            <i class="bi bi-box"></i> Processing
        </div>

        <div class="timeline-step">
            <i class="bi bi-truck"></i> Shipped
        </div>

        <div class="timeline-step">
            <i class="bi bi-house"></i> Delivered
        </div>

    </div>


    <a asp-controller="Seller" asp-action="Orders" class="btn btn-dark mt-3">
        ← Back to Orders
    </a>

</div>