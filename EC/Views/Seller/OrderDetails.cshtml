@model List<EC.Models.OrderDetailViewModel>
@using System.Security.Claims

@{
    ViewData["Title"] = "Order Details";
    Layout = "_Layout";
}

<style>
    body {
        background: #f1f5f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .order-container {
        max-width: 1100px;
        margin: auto;
        padding: 30px 15px;
    }

    .card-box {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 6px 20px rgba(0,0,0,0.04);
        padding: 20px;
        margin-bottom: 20px;
    }

    .order-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .order-title {
        font-weight: 700;
        font-size: 20px;
    }

    .status-badge {
        padding: 8px 16px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
    }

    .status-Pending { background: #fff3cd; color: #856404; }
    .status-Processing { background: #cfe2ff; color: #084298; }
    .status-Shipped { background: #cff4fc; color: #055160; }
    .status-Delivered { background: #d1e7dd; color: #0f5132; }
    .status-Cancelled { background: #f8d7da; color: #842029; }

    .summary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .card-box h5 {
        margin-bottom: 15px;
        border-bottom: 1px solid #eee;
        padding-bottom: 8px;
    }

    .info-text {
        font-size: 14px;
        margin-bottom: 8px;
    }

    .highlight {
        font-size: 20px;
        font-weight: 700;
        color: #dc2626;
    }

    /* PRODUCT */
    .product-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 15px;
        background: #fff;
        transition: 0.25s;
    }

    .product-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    }

    .product-left {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .product-img {
        width: 80px;
        height: 80px;
        border-radius: 12px;
        object-fit: cover;
    }

    .price {
        font-weight: 700;
        font-size: 18px;
        color: #dc2626;
    }

    /* TRACKING */
    .tracking-container {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
        position: relative;
    }

    .tracking-container::before {
        content: "";
        position: absolute;
        top: 20px;
        left: 5%;
        width: 90%;
        height: 4px;
        background: #e5e7eb;
        z-index: 0;
    }

    .track-step {
        text-align: center;
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .circle {
        width: 40px;
        height: 40px;
        margin: auto;
        border-radius: 50%;
        background: #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    .track-step.done .circle {
        background: #10b981;
        color: white;
    }

    .track-step.active .circle {
        background: #3b82f6;
        color: white;
        transform: scale(1.1);
    }

    .track-step p {
        margin-top: 8px;
        font-size: 13px;
    }

    /* CANCEL UI */
    .cancel-box {
        text-align: center;
        padding: 25px;
        border-radius: 12px;
        background: #f8d7da;
        color: #842029;
    }

    .cancel-icon {
        font-size: 40px;
        margin-bottom: 10px;
    }

    .btn-back {
        background: #111827;
        color: #fff;
        border-radius: 8px;
        padding: 10px 18px;
        text-decoration: none;
    }

    @@media (max-width: 768px) {
        .summary-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="order-container">

    @{
        var order = Model.FirstOrDefault();
    }

    <!-- HEADER -->
    <div class="card-box order-header">
        <div class="order-title">📦 Order Details</div>
        <div class="status-badge status-@order?.Status">
            @order?.Status
        </div>
    </div>

    <!-- SUMMARY -->
    <div class="summary-grid">

        <div class="card-box">
            <h5>Order Summary</h5>

            @{
                decimal total = 0;
            }

            @foreach (var item in Model)
            {
                total += item.Price * item.Quantity;
            }

            <p class="info-text"><strong>Total Items:</strong> @Model.Count</p>
            <p class="info-text"><strong>Total Amount:</strong> <span class="highlight">₹@total</span></p>
            <p class="info-text"><strong>Order Date:</strong> @DateTime.Now.ToString("dd MMM yyyy")</p>
        </div>

        <div class="card-box">
            <h5>Customer Details</h5>

            @{
                var Order = Model.FirstOrDefault();
            }

            <p class="info-text"><strong>Name:</strong> @Order?.UserName</p>
            <p class="info-text"><strong>Phone:</strong> +91 @Order?.Phone</p>
            <p class="info-text"><strong>Address:</strong> @Order?.Address</p>
        </div>

    </div>

    <!-- PAYMENT -->
    <div class="card-box">
        <h5>Payment Method</h5>
        <p class="info-text">💳 Cash on Delivery (COD)</p>
    </div>

    <!-- PRODUCTS -->
    @foreach (var item in Model)
    {
        <div class="product-card">
            <div class="product-left">
                <img src="/product-images/@item.ProductImage" class="product-img" />
                <div>
                    <div>@item.ProductName</div>
                    <div>Qty: @item.Quantity</div>
                </div>
            </div>
            <div class="price">₹@(item.Price * item.Quantity)</div>
        </div>
    }

    <!-- TRACKING -->
    @{
        var status = order?.Status ?? "";
        int step = 1;

        if (status == "Processing") step = 2;
        else if (status == "Shipped") step = 3;
        else if (status == "Delivered") step = 4;
    }

    <div class="card-box">
        <h5>Order Tracking</h5>

        @if (status == "Cancelled")
        {
            <div class="cancel-box">
                <div class="cancel-icon">✖</div>
                <h4>Order Cancelled</h4>
                <p>Your order has been cancelled.</p>
            </div>
        }
        else
        {
            <div class="tracking-container">

                <div class="track-step @(step >= 1 ? "done" : "") @(step == 1 ? "active" : "")">
                    <div class="circle">1</div>
                    <p>Placed</p>
                </div>

                <div class="track-step @(step >= 2 ? "done" : "") @(step == 2 ? "active" : "")">
                    <div class="circle">2</div>
                    <p>Processing</p>
                </div>

                <div class="track-step @(step >= 3 ? "done" : "") @(step == 3 ? "active" : "")">
                    <div class="circle">3</div>
                    <p>Shipped</p>
                </div>

                <div class="track-step @(step >= 4 ? "done" : "") @(step == 4 ? "active" : "")">
                    <div class="circle">4</div>
                    <p>Delivered</p>
                </div>

            </div>
        }
    </div>

    <!-- BACK -->
    @{
        var role = User.FindFirst(ClaimTypes.Role)?.Value;
    }

    @if (role == "Admin")
    {
        <a asp-controller="Admin" asp-action="Orders" class="btn-back">← Back</a>
    }
    else if (role == "Seller")
    {
        <a asp-controller="Seller" asp-action="Orders" class="btn-back">← Back</a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" class="btn-back">← Home</a>
    }

</div>