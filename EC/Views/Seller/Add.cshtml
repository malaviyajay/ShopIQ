@model EC.Models.Product

@{
    ViewData["Title"] = "Add Product";
    Layout = "_Layout";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>

    body {
        background: #f3f3f3;
    }

    .add-card {
        max-width: 650px;
        margin: auto;
        margin-top: 40px;
        background: white;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    .add-title {
        font-weight: 700;
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
    }

    .custom-input {
        border-radius: 8px;
        padding: 10px;
    }

    .image-preview {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 10px;
        margin-top: 10px;
        display: none;
    }

    .qty-box {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .qty-btn {
        width: 35px;
        height: 35px;
        border: none;
        background: #eee;
        border-radius: 6px;
    }

    .save-btn {
        width: 100%;
        background: #f7ca00;
        border: none;
        padding: 12px;
        border-radius: 25px;
        font-weight: 600;
    }

</style>


<div class="container">

    <div class="add-card">

        <h3 class="add-title">
            <i class="fas fa-plus-circle"></i> Add New Product
        </h3>

        <form asp-action="Add" asp-controller="Seller" method="post" enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <label class="form-label">Product Name</label>
            <input asp-for="Name" class="form-control custom-input" required />

            <div class="row mt-3">

                <div class="col-md-6">
                    <label class="form-label">Price (₹)</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control custom-input" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Category</label>

                    <select asp-for="CategoryId"
                            asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))"
                            class="form-control custom-input" required>

                        <option value="">Select Category</option>

                    </select>

                </div>

            </div>


            <label class="form-label mt-3">Product Image</label>

            <input type="file"
                   name="ImageFile"
                   class="form-control"
                   accept="image/*"
                   onchange="previewImage(event)"
                   required />

            <img id="preview" class="image-preview" />


            <label class="form-label mt-3">Initial Quantity</label>

            <div class="qty-box">

                <button type="button" class="qty-btn" onclick="changeQty(-1)">-</button>

                <input asp-for="Quantity"
                       id="qty"
                       type="number"
                       value="1"
                       min="1"
                       class="form-control"
                       style="width:80px;" />

                <button type="button" class="qty-btn" onclick="changeQty(1)">+</button>

            </div>


            <button type="submit" class="save-btn mt-4">
                <i class="fas fa-check"></i> Add Product
            </button>

            <a asp-action="Dashboard"
               asp-controller="Seller"
               class="btn btn-outline-secondary mt-2 w-100">
                Back
            </a>

        </form>

    </div>
</div>


@section Scripts {

    <script>

        function changeQty(val){

        let q=document.getElementById("qty");

        let current=parseInt(q.value);

        current=current+val;

        if(current<1) current=1;

        q.value=current;

        }

        function previewImage(event){

        const reader=new FileReader();

        reader.onload=function(){

        const img=document.getElementById("preview");

        img.src=reader.result;

        img.style.display="block";

        }

        reader.readAsDataURL(event.target.files[0]);

        }

    </script>

}