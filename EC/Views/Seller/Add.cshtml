@model EC.Models.Product

@{
    ViewData["Title"] = "Add Product";
    Layout = "_Layout";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary-color: #007185;
        --secondary-color: #f7ca00;
        --secondary-hover: #e0b700;
        --text-main: #0F1111;
        --text-muted: #565959;
        --bg-light: #f3f3f3;
        --white: #ffffff;
        --border-color: #e7e7e7;
    }

    body {
        background: var(--bg-light);
        font-family: "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: var(--text-main);
    }

    .add-product-bg {
        padding: 40px 15px;
        min-height: 80vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
    }

    .dashboard-card {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        width: 100%;
        max-width: 650px;
        overflow: hidden;
    }

    /* ===== HEADER ===== */
    .card-header-custom {
        background: var(--white);
        border-bottom: 1px solid var(--border-color);
        padding: 25px 30px;
    }

        .card-header-custom h3 {
            font-weight: 700;
            font-size: 1.5rem;
            margin: 0 0 5px 0;
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-header-custom p {
            margin: 0;
            font-size: 0.95rem;
            color: var(--text-muted);
        }

    /* ===== FORM STYLES ===== */
    .form-body {
        padding: 30px;
    }

    .form-label {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-label i {
            color: var(--text-muted);
            width: 16px;
            text-align: center;
        }

    .custom-input {
        width: 100%;
        border: 1px solid #d5d9d9;
        border-radius: 8px;
        padding: 12px 15px;
        font-size: 0.95rem;
        color: var(--text-main);
        background-color: var(--white);
        transition: all 0.2s;
        box-shadow: 0 2px 5px rgba(213,217,217,0.2) inset;
        margin-bottom: 20px;
    }

        .custom-input:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(0, 113, 133, 0.15);
            outline: none;
        }

    /* ===== QUANTITY GROUP ===== */
    .quantity-container {
        display: flex;
        align-items: center;
        margin-bottom: 25px;
    }

    .qty-btn {
        background: var(--bg-light);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .qty-btn:hover {
            background: #e3e6e6;
        }

    .qty-btn-minus {
        border-radius: 8px 0 0 8px;
    }

    .qty-btn-plus {
        border-radius: 0 8px 8px 0;
    }

    .qty-input {
        width: 70px;
        height: 42px;
        border: 1px solid var(--border-color);
        border-left: none;
        border-right: none;
        text-align: center;
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-main);
    }

    /* ===== BUTTONS ===== */
    .btn-save {
        background: var(--secondary-color);
        border: 1px solid transparent;
        color: var(--text-main);
        padding: 12px 25px;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 50px;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 2px 5px rgba(213,217,217,0.5);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        margin-bottom: 15px;
        text-decoration: none;
    }

        .btn-save:hover {
            background: var(--secondary-hover);
            transform: translateY(-1px);
            color: var(--text-main);
        }

    .btn-back-custom {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 12px 25px;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 50px;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        text-decoration: none;
    }

        .btn-back-custom:hover {
            background: var(--bg-light);
            border-color: #d1d1d1;
            color: var(--text-main);
        }
</style>

<div class="container add-product-bg">
    <div class="dashboard-card">

        <div class="card-header-custom">
            <h3><i class="fas fa-plus-circle text-primary"></i> Add New Product</h3>
            <p>Fill out the details below to add a new item to the ShopIQ inventory.</p>
        </div>

        <div class="form-body">
            <form asp-action="Add" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <label class="form-label"><i class="fas fa-tag"></i> Product Name</label>
                <input asp-for="Name" class="custom-input" placeholder="e.g., Wireless Bluetooth Headphones" required />

                <div class="row">
                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-rupee-sign"></i> Price (₹)</label>
                        <input asp-for="Price" class="custom-input" type="number" step="0.01" placeholder="0.00" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><i class="fas fa-list"></i> Category</label>
                        <select asp-for="CategoryId" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))" class="custom-input" required>
                            <option value="">-- Select Category --</option>
                        </select>
                    </div>
                </div>

                <label class="form-label"><i class="fas fa-image"></i> Product Image</label>
                <input type="file" name="ImageFile" class="custom-input" accept="image/*" required>

                <label class="form-label"><i class="fas fa-cubes"></i> Initial Quantity</label>
                <div class="quantity-container">
                    <button type="button" class="qty-btn qty-btn-minus" onclick="changeQuantity(-1)">
                        <i class="fas fa-minus"></i>
                    </button>

                    <input asp-for="Quantity" id="quantity-input" class="qty-input" type="number" value="1" min="1" required />

                    <button type="button" class="qty-btn qty-btn-plus" onclick="changeQuantity(1)">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <button type="submit" class="btn-save">
                        <i class="fas fa-check"></i> Add Product
                    </button>

                    <a asp-controller="Seller" asp-action="Dashboard" class="btn-back-custom">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeQuantity(delta) {
            const qtyInput = document.getElementById('quantity-input');
            let current = parseInt(qtyInput.value) || 1;
            current += delta;
            if (current < 1) current = 1;
            qtyInput.value = current;
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}