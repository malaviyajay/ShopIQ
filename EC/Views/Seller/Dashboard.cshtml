@model EC.Models.SellerDashboardViewModel

@{
    ViewData["Title"] = "Seller Dashboard";
    Layout = "_Layout";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        background: #f4f6f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .admin-dashboard {
        padding: 30px;
        max-width: 1400px;
        margin: auto;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

    .dash-title {
        font-size: 26px;
        font-weight: 700;
    }

    .dash-btn {
        padding: 10px 18px;
        border-radius: 8px;
        background: white;
        border: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        text-decoration: none;
        color: #444;
        font-weight: 600;
        display: inline-flex;
        gap: 8px;
        align-items: center;
    }

    .dash-btn:hover {
        transform: translateY(-2px);
        color: #0d6efd;
    }

    /* ===== CARDS ===== */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        padding: 24px;
        border-radius: 16px;
        color: white;
        position: relative;
        overflow: hidden;
        transition: 0.3s;
    }

    .stat-card:hover {
        transform: translateY(-5px);
    }

    .stat-card h3 {
        font-size: 14px;
        opacity: 0.85;
        margin-bottom: 8px;
    }

    .stat-card p {
        font-size: 28px;
        font-weight: bold;
    }

    .icon-bg {
        position: absolute;
        right: -10px;
        bottom: -10px;
        font-size: 60px;
        opacity: 0.2;
    }

    .card-blue { background: linear-gradient(135deg, #0d6efd, #004fb1); }
    .card-purple { background: linear-gradient(135deg, #6f42c1, #4e2b91); }
    .card-orange { background: linear-gradient(135deg, #fd7e14, #d35400); }
    .card-green { background: linear-gradient(135deg, #198754, #0f5132); }

    /* ===== SECTIONS ===== */
    .dashboard-section {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        height: 100%;
    }

    .section-title {
        font-weight: 700;
        margin-bottom: 20px;
    }

    /* ===== PREMIUM TABLE ===== */
    .admin-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        border-radius: 12px;
        overflow: hidden;
        font-size: 14px;
    }

    .admin-table thead th {
        background: #f9fafb;
        color: #6b7280;
        font-size: 12px;
        text-transform: uppercase;
        padding: 14px 16px;
    }

    .admin-table tbody td {
        padding: 16px;
        border-bottom: 1px solid #eee;
    }

    .admin-table tbody tr:nth-child(even) {
        background: #fafafa;
    }

    .admin-table tbody tr:hover {
        background: #f1f5f9;
        transform: scale(1.01);
    }

    .admin-table td.text-end {
        text-align: right;
    }

    /* FILTER */
    .filter-box {
        background: white;
        padding: 20px;
        border-radius: 12px;
        margin: 25px 0;
    }
</style>

<div class="admin-dashboard">

    <!-- HEADER -->
    <div class="dashboard-header">
        <h1 class="dash-title"><i class="fas fa-store"></i> Seller Dashboard</h1>

        <div class="d-flex gap-2">
            <a asp-controller="Seller" asp-action="Orders" class="dash-btn">
                <i class="fas fa-receipt"></i> Orders
            </a>
            <a asp-controller="Seller" asp-action="Products" class="dash-btn">
                <i class="fas fa-box"></i> Products
            </a>
        </div>
    </div>

    <!-- ALERT -->
    @if (Model.LowStockCount > 0)
    {
        <div class="alert alert-warning">
            ⚠ Low Stock: @Model.LowStockCount products
        </div>
    }

    <!-- CARDS -->
    <div class="stat-grid">
        <div class="stat-card card-blue">
            <i class="fas fa-box icon-bg"></i>
            <h3>Total Products</h3>
            <p>@Model.ProductCount</p>
        </div>

        <div class="stat-card card-purple">
            <i class="fas fa-shopping-bag icon-bg"></i>
            <h3>Total Orders</h3>
            <p>@Model.Orders.Count</p>
        </div>

        <div class="stat-card card-orange">
            <i class="fas fa-rupee-sign icon-bg"></i>
            <h3>Revenue</h3>
            <p>₹@Model.Revenue.ToString("N0")</p>
        </div>

        <div class="stat-card card-green">
            <i class="fas fa-chart-line icon-bg"></i>
            <h3>Profit</h3>
            <p>₹@Model.Profit.ToString("N0")</p>
        </div>
    </div>

    <!-- TABLES -->
    <div class="row g-4">

        <div class="col-lg-5">
            <div class="dashboard-section">
                <h5 class="section-title">Top Selling Products</h5>
                <div class="table-responsive">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Sold</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.TopProducts.Take(5))
                            {
                                <tr>
                                    <td class="fw-bold text-primary">@p.TopProductName</td>
                                    <td class="text-end fw-bold">@p.TotalSold</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="dashboard-section">
                <h5 class="section-title">Recent Orders</h5>
                <div class="table-responsive">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Date</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model.Recentorders.Take(5))
                            {
                                <tr>
                                    <td class="fw-semibold">@o.Name</td>
                                    <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                                    <td class="text-end fw-bold" style="color:#dc2626;">
                                        ₹@o.Amount.ToString("N0")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

</div>

<!-- FILTER -->
<div class="filter-box">
    <div class="row">
        <div class="col-md-4">
            <input type="date" id="fromDate" class="form-control">
        </div>
        <div class="col-md-4">
            <input type="date" id="toDate" class="form-control">
        </div>
        <div class="col-md-4">
            <button class="btn btn-primary w-100" onclick="loadCharts()">Filter</button>
        </div>
    </div>
</div>

<!-- CHARTS -->
<div class="row g-4 mt-3">
    <div class="col-lg-6">
        <div class="dashboard-section">
            <h3 class="section-title">Monthly Revenue & Profit</h3>
            <canvas id="RevenueChart"></canvas>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="dashboard-section">
            <h3 class="section-title">Monthly Orders</h3>
            <canvas id="ordersChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let revenueChart;
    let ordersChart;

    document.addEventListener("DOMContentLoaded", async function () {
        const year = new Date().getFullYear();

        const firstDay = new Date(year, 0, 1);
        const lastDay = new Date(year, 11, 31);

        document.getElementById("fromDate").value = firstDay.toISOString().split('T')[0];
        document.getElementById("toDate").value = lastDay.toISOString().split('T')[0];

        await loadCharts();
    });

    async function getChartData() {
        const fromDate = document.getElementById("fromDate").value;
        const toDate = document.getElementById("toDate").value;

        try {
            const response = await fetch(`/api/chart/seller-admin-dashboard?fromDate=${fromDate}&toDate=${toDate}`);
            return await response.json();
        } catch (ex) {
            console.error(ex);
            alert("Something went wrong");
            return [];
        }
    }

    async function loadCharts() {
        const data = await getChartData();

        if (revenueChart) revenueChart.destroy();
        if (ordersChart) ordersChart.destroy();

        const labels = data.map(x => x.month);

        revenueChart = new Chart(document.getElementById('RevenueChart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    { label: 'Revenue', data: data.map(x => x.revenue), borderWidth: 2, tension: 0.4 },
                    { label: 'Profit', data: data.map(x => x.profit), borderWidth: 2, tension: 0.4 }
                ]
            }
        });

        ordersChart = new Chart(document.getElementById('ordersChart'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    { label: 'Orders', data: data.map(x => x.orders), borderWidth: 1 }
                ]
            }
        });
    }
</script>
}