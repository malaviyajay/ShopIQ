@model EC.Models.SellerDashboardViewModel 

@{ ViewData["Title"] = "Seller Dashboard";
Layout = "_Layout"; 
} 

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet"> 

<style> 

        :root { 
            --primary-color: #007185; 
            --secondary-color: #f7ca00; 
            --secondary-hover: #e0b700; 
            --text-main: #0F1111; 
            --text-muted: #565959; 
            --bg-light: #f3f3f3; 
            --white: #ffffff; 
            --border-color: #e7e7e7; 
            --success: #007600; 
            --danger: #B12704; 
        } 
        body { 
            background: var(--bg-light); 
            font-family: "Segoe UI",Roboto,sans-serif; 
            color: var(--text-main); 
        } 
        .dashboard-wrapper { 
            padding: 40px 15px; 
            max-width: 1300px; 
            margin: 0 auto; 
        } 
        .dashboard-header { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            margin-bottom: 25px; 
            flex-wrap: wrap; 
            gap: 15px; 
        } 
        .dash-title { 
            font-size: 1.75rem; 
            font-weight: 700; 
            margin: 0; 
            display: flex; 
            align-items: center; 
            gap: 12px; 
        } 
        .dash-btn { 
            background: var(--white); 
            border: 1px solid var(--border-color); 
            color: var(--text-main); 
            padding: 10px 18px; 
            border-radius: 8px; 
            font-weight: 600; 
            font-size: 0.9rem; 
            text-decoration: none; 
            transition: all .2s; 
            box-shadow: 0 2px 5px rgba(0,0,0,.05); 
            display: inline-flex; 
            align-items: center; 
            gap: 8px; 
        } 
        .dash-btn:hover { 
            background: var(--bg-light); 
            color: var(--primary-color); 
        } 
        .dash-btn-primary { 
            background: var(--secondary-color); 
            border-color: transparent; 
        } 
        .dash-btn-primary:hover { 
            background: var(--secondary-hover); 
        } 
        .stat-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit,minmax(220px,1fr)); 
            gap: 20px; 
            margin-bottom: 30px; 
        } 
        .stat-card { 
            background: var(--white); 
            border: 1px solid var(--border-color); 
            border-radius: 12px; 
            padding: 25px 20px; 
            display: flex; 
            justify-content: space-between; 
            align-items: flex-start; 
            transition: transform .2s; 
        } 
        .stat-card:hover { 
            transform: translateY(-3px); 
            box-shadow: 0 8px 25px rgba(0,0,0,.05); 
        } 
        .stat-info h3 { 
            font-size: .85rem; 
            font-weight: 600; 
            color: var(--text-muted); 
            text-transform: uppercase; 
            margin: 0 0 8px 0; 
        } 
        .stat-info p { 
            font-size: 1.8rem; 
            font-weight: 700; 
            margin: 0; 
        } 
        .stat-icon { 
            width: 45px; 
            height: 45px; 
            border-radius: 10px; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 1.3rem; 
        } 
        .bg-blue-soft { 
            background: rgba(0,113,133,.1); 
            color: var(--primary-color); 
        } 
        .bg-gold-soft { 
            background: rgba(247,202,0,.15); 
            color: #d4a000; 
        } 
        .bg-green-soft { 
            background: rgba(0,118,0,.1); 
            color: var(--success); 
        } 
        .dashboard-section { 
            background: var(--white); 
            border: 1px solid var(--border-color); 
            border-radius: 12px; 
            padding: 25px; 
        } 
        .section-title { 
            font-size: 1.1rem; 
            font-weight: 700; 
            margin-bottom: 20px; 
            padding-bottom: 12px; 
            border-bottom: 1px solid var(--border-color); 
        } 
        .admin-table th { 
            font-size: .8rem; 
            font-weight: 600; 
            text-transform: uppercase; 
            color: var(--text-muted); 
            padding: 12px 10px; 
            border-bottom: 2px solid var(--border-color); 
        } 
        .admin-table td { 
            padding: 15px 10px; 
            border-bottom: 1px solid var(--border-color); 
            font-size: .95rem; 
        } 
        .admin-table tbody tr:hover { 
            background: #f8f9fa; 
        } 
</style> 

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="dashboard-wrapper"> 
        @if (Model.LowStockCount > 0) { 
            <div class="alert alert-warning"> 
                <strong>⚠ Low Stock Alert!</strong> You have @Model.LowStockCount product(s) with low inventory. 
            </div> 
        } 
</div>
<div class="dashboard-header"> 
    <h1 class="dash-title"><i class="fas fa-store text-primary"></i> Seller Dashboard</h1> 
    <div class="dash-actions"> 
        <a asp-controller="Seller" asp-action="Orders" class="dash-btn"> 
            <i class="fas fa-receipt"></i> Orders 
        </a> 
        <a asp-controller="Seller" asp-action="Products" class="dash-btn dash-btn-primary"> 
            <i class="fas fa-box"></i> Manage Products 
        </a> 
    </div> 
</div> 
<div class="stat-grid"> 
    <div class="stat-card"> 
        <div class="stat-info"> 
            <h3>Products</h3> 
            <p>@Model.ProductCount</p> 
        </div> 
        <div class="stat-icon bg-blue-soft"><i class="fas fa-boxes"></i></div> 
    </div> 
    <div class="stat-card"> 
        <div class="stat-info"> 
            <h3>Total Orders</h3> 
            <p>@Model.Orders.Count</p> 
        </div> 
        <div class="stat-icon bg-blue-soft"><i class="fas fa-shopping-cart"></i></div> 
    </div> 
    <div class="stat-card"> 
        <div class="stat-info"> 
            <h3>Revenue</h3> 
            <p>₹@Model.Revenue.ToString("N0")</p> 
        </div> 
        <div class="stat-icon bg-gold-soft"><i class="fas fa-indian-rupee-sign"></i></div> 
    </div> 
    <div class="stat-card"> 
        <div class="stat-info"> 
            <h3>Profit</h3> 
            <p>₹@Model.Profit.ToString("N0")</p> 
        </div> 
        <div class="stat-icon bg-green-soft"><i class="fas fa-chart-line"></i></div> 
    </div> 
</div> 
<div class="row g-4"> 
    <table class="table table-hover align-middle admin-table mb-0"> 
        <thead class="table-light"> 
            <tr> 
                <th style="width:70%">Product Name</th> 
                <th class="text-end">Sold</th> 
            </tr> 
        </thead> 
        <tbody> 
            @if (Model.TopProducts != null && Model.TopProducts.Any()) { 
                foreach (var p in Model.TopProducts.Take(5)) { 
                    <tr> 
                        <td class="fw-semibold">@p.TopProductName</td> 
                        <td class="text-end fw-bold text-success">@p.TotalSold</td> 
                    </tr> 
                } 
            } else { 
                <tr> 
                    <td colspan="2" class="text-center text-muted py-4"> 
                        <i class="fas fa-box-open me-2"></i>No top selling products yet 
                    </td> 
                </tr> 
            } 
        </tbody> 
    </table> 
    <table class="table table-hover align-middle admin-table mb-0"> 
        <thead class="table-light"> 
            <tr> 
                <th style="width:40%">Customer</th> 
                <th style="width:35%">Order Date</th> 
                <th class="text-end">Amount</th> 
            </tr> 
        </thead> 
        <tbody> 
            @if (Model.Recentorders != null && Model.Recentorders.Any()) { 
                foreach (var o in Model.Recentorders.Take(5)) { 
                    <tr> 
                        <td class="fw-semibold">@o.Name</td> 
                        <td class="text-muted"> 
                            <i class="far fa-calendar-alt me-1"></i> @o.OrderDate.ToString("dd MMM yyyy") 
                        </td> 
                        <td class="text-end fw-bold text-danger"> ₹@o.Amount.ToString("N0") </td> 
                    </tr> 
                } 
            } else { 
                <tr> 
                    <td colspan="3" class="text-center text-muted py-4"> 
                        <i class="fas fa-shopping-cart me-2"></i>No recent orders 
                    </td> 
                </tr> 
            } 
        </tbody> 
    </table> 
</div> 
<div class="row mb-3"> 
    <div class="col-md-3"> 
        <label class="form-label">From Date</label> 
        <input type="date" id="fromDate" class="form-control"> 
    </div> 
    <div class="col-md-3"> 
        <label class="form-label">To Date</label> 
        <input type="date" id="toDate" class="form-control"> 
    </div> 
    <div class="col-md-2 d-flex align-items-end"> 
        <button class="btn btn-primary w-100" onclick="loadCharts()"> Filter </button> 
    </div> 
</div> 
<div class="row g-4 mt-3"> 
    <div class="col-lg-6"> 
        <div class="dashboard-section"> 
            <h3 class="section-title">Monthly Revenue & Profit</h3> 
           <canvas id="revenueChart" style="height:300px;"></canvas>
        </div> 
    </div> 
    <div class="col-lg-6"> 
        <div class="dashboard-section"> 
            <h3 class="section-title">Monthly Orders</h3> 
           <canvas id="ordersChart" style="height:300px;"></canvas>
        </div> 
    </div> 
</div> 
 
@section Scripts {

    <script> 
        let revenueChart; 
        let ordersChart; 
        document.addEventListener("DOMContentLoaded", async function () {
            const today = new Date();
            const firstDay = new Date(today.getFullYear(), 0, 1);

            document.getElementById("fromDate").value = firstDay.toISOString().split('T')[0];
            document.getElementById("toDate").value = today.toISOString().split('T')[0];

            await loadCharts();
        });


        async function getChartData() {

            const fromDate = document.getElementById("fromDate").value;
            const toDate = document.getElementById("toDate").value;

            try {
                const response = await fetch(`/api/chart/seller-admin-dashboard?fromDate=${fromDate}&toDate=${toDate}`);

                const data = await response.json();

                return data;
            } 
            catch (ex) {
                console.error(ex);
                alert("Something went wrong");
                return [];
            }

        }

    
        async function loadCharts() {

            const data = await getChartData();

            if (revenueChart) revenueChart.destroy();
            if (ordersChart) ordersChart.destroy();

            revenueChart = new Chart(document.getElementById('revenueChart'), {
                type: 'line',
                data: {
                    labels: data.map(x => x.month),
                    datasets: [
                        { label: 'Revenue', data: data.map(x => x.revenue) },
                        { label: 'Profit', data: data.map(x => x.profit) }
                    ]
                }
            });

            ordersChart = new Chart(document.getElementById('ordersChart'), {
                type: 'bar',
                data: {
                    labels: data.map(x => x.month),
                    datasets: [
                        { label: 'Orders', data: data.map(x => x.orders) }
                    ]
                }
            });
        }
    </script>
 

}