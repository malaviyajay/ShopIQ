@model EC.Models.SellerDashboardViewModel

@{
    ViewData["Title"] = "Seller Dashboard";
    Layout = "_Layout";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary-color: #007185;
        --secondary-color: #f7ca00;
        --secondary-hover: #e0b700;
        --text-main: #0F1111;
        --text-muted: #565959;
        --bg-light: #f3f3f3;
        --white: #ffffff;
        --border-color: #e7e7e7;
        --success: #007600;
        --danger: #B12704;
    }

    body {
        background: var(--bg-light);
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        color: var(--text-main);
    }

    .admin-dashboard {
        padding: 40px 15px;
        max-width: 1300px;
        margin: 0 auto;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .dash-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .dash-btn {
        background: var(--white);
        border: 1px solid var(--border-color);
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: .2s;
    }

    .dash-btn:hover {
        background: var(--bg-light);
        color: var(--primary-color);
    }

    .dash-btn-primary {
        background: var(--secondary-color);
        border: none;
    }

    .dash-btn-primary:hover {
        background: var(--secondary-hover);
    }

    /* STAT CARDS */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 25px;
        display: flex;
        justify-content: space-between;
    }

    .stat-info h3 {
        font-size: .9rem;
        color: var(--text-muted);
    }

    .stat-info p {
        font-size: 1.8rem;
        font-weight: bold;
    }

    .stat-icon {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .icon-blue { background: rgba(0,113,133,.1); color: var(--primary-color); }
    .icon-gold { background: rgba(247,202,0,.2); color: #d4a000; }
    .icon-green { background: rgba(0,118,0,.1); color: var(--success); }

    /* SECTIONS */
    .dashboard-section {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 20px;
    }

    .section-title {
        font-weight: 700;
        margin-bottom: 15px;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 10px;
    }

    /* TABLE */
    .admin-table th {
        font-size: .85rem;
        color: var(--text-muted);
    }

    .admin-table td {
        padding: 12px;
    }
</style>

<div class="admin-dashboard">

    <!-- HEADER -->
    <div class="dashboard-header">
        <h1 class="dash-title">
            <i class="fas fa-store text-primary"></i> Seller Dashboard
        </h1>

        <div class="dash-actions">
            <a asp-controller="Seller" asp-action="Orders" class="dash-btn">
                <i class="fas fa-receipt"></i> Orders
            </a>
            <a asp-controller="Seller" asp-action="Products" class="dash-btn dash-btn-primary">
                <i class="fas fa-box"></i> Manage Products
            </a>
        </div>
    </div>

    <!-- ALERT -->
    @if (Model.LowStockCount > 0)
    {
        <div class="alert alert-warning">
            ⚠ Low Stock: @Model.LowStockCount products
        </div>
    }

    <!-- STATS -->
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Products</h3>
                <p>@Model.ProductCount</p>
            </div>
            <div class="stat-icon icon-blue"><i class="fas fa-box"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Orders</h3>
                <p>@Model.Orders.Count</p>
            </div>
            <div class="stat-icon icon-blue"><i class="fas fa-shopping-cart"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Revenue</h3>
                <p>₹@Model.Revenue.ToString("N0")</p>
            </div>
            <div class="stat-icon icon-gold"><i class="fas fa-rupee-sign"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Profit</h3>
                <p>₹@Model.Profit.ToString("N0")</p>
            </div>
            <div class="stat-icon icon-green"><i class="fas fa-chart-line"></i></div>
        </div>
    </div>

    <!-- TABLES -->
    <div class="row g-4">

        <!-- TOP PRODUCTS -->
        <div class="col-lg-5">
            <div class="dashboard-section">
                <h3 class="section-title">Top Selling Products</h3>
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Sold</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.TopProducts.Take(5))
                        {
                            <tr>
                                <td>@p.TopProductName</td>
                                <td class="text-end">@p.TotalSold</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- RECENT ORDERS -->
        <div class="col-lg-7">
            <div class="dashboard-section">
                <h3 class="section-title">Recent Orders</h3>
                <table class="table admin-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Date</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.Recentorders.Take(5))
                        {
                            <tr>
                                <td>@o.Name</td>
                                <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                                <td class="text-end">₹@o.Amount.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

</div>

<div class="row mb-3"> 
    <div class="col-md-3"> 
        <label class="form-label">From Date</label> 
        <input type="date" id="fromDate" class="form-control"> 
    </div> 
    <div class="col-md-3"> 
        <label class="form-label">To Date</label> 
        <input type="date" id="toDate" class="form-control"> 
    </div> 
    <div class="col-md-2 d-flex align-items-end"> 
        <button class="btn btn-primary w-100" onclick="loadCharts()"> Filter </button> 
    </div> 
</div> 
<div class="row g-4 mt-3">

    <div class="col-lg-6">
        <div class="dashboard-section">
            <h3 class="section-title">Monthly Revenue & Profit</h3>
            <canvas id="RevenueChart" height="300"></canvas>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="dashboard-section">
            <h3 class="section-title">Monthly Orders</h3>
            <canvas id="ordersChart" height="300"></canvas>
        </div>
    </div>

</div>




       @section Scripts {

    <script> 
        let revenueChart; 
        let ordersChart; 
        document.addEventListener("DOMContentLoaded", async function () {
            const today = new Date();
            const firstDay = new Date(today.getFullYear(), 0, 1);

            document.getElementById("fromDate").value = firstDay.toISOString().split('T')[0];
            document.getElementById("toDate").value = today.toISOString().split('T')[0];

            await loadCharts();
        });


        async function getChartData() {

            const fromDate = document.getElementById("fromDate").value;
            const toDate = document.getElementById("toDate").value;

            try {
                const response = await fetch(`/api/chart/seller-admin-dashboard?fromDate=${fromDate}&toDate=${toDate}`);

                const data = await response.json();

                return data;
            } 
            catch (ex) {
                console.error(ex);
                alert("Something went wrong");
                return [];
            }

        }

    
        async function loadCharts() {

            const data = await getChartData();

            if (revenueChart) revenueChart.destroy();
            if (ordersChart) ordersChart.destroy();

            revenueChart = new Chart(document.getElementById('RevenueChart'), {
                type: 'line',
                data: {
                    labels: data.map(x => x.month),
                    datasets: [
                        { label: 'Revenue', data: data.map(x => x.revenue) },
                        { label: 'Profit', data: data.map(x => x.profit) }
                    ]
                }
            });

            ordersChart = new Chart(document.getElementById('ordersChart'), {
                type: 'bar',
                data: {
                    labels: data.map(x => x.month),
                    datasets: [
                        { label: 'Orders', data: data.map(x => x.orders) }
                    ]
                }
            });
        }
       
    </script>
 

} 