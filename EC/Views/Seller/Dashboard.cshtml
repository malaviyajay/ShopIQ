@model EC.Models.SellerDashboardViewModel

@{
    ViewData["Title"] = "Seller Dashboard";
    Layout = "_Layout";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">



<style>
    :root {
        /* Dashboard Theme Colors - Match Admin UI */
        --primary-color: #007185;
        --secondary-color: #f7ca00;
        --secondary-hover: #e0b700;
        --text-main: #0F1111;
        --text-muted: #565959;
        --bg-light: #f3f3f3;
        --white: #ffffff;
        --border-color: #e7e7e7;
        --success: #007600;
        --danger: #B12704;
    }

    body {
        background: var(--bg-light);
        font-family: "Segoe UI", Roboto, sans-serif;
        color: var(--text-main);
    }

    .dashboard-wrapper {
        padding: 40px 15px;
        max-width: 1300px;
        margin: 0 auto;
    }

    /* ===== HEADER ===== */
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .dash-btn {
        background: var(--white);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.2s;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .dash-btn:hover {
            background: var(--bg-light);
            color: var(--primary-color);
        }

    .dash-btn-primary {
        background: var(--secondary-color);
        border-color: transparent;
    }

        .dash-btn-primary:hover {
            background: var(--secondary-hover);
        }

    /* ===== STAT CARDS ===== */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 25px 20px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        transition: transform 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.05);
        }

    .stat-info h3 {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        margin: 0 0 8px 0;
    }

    .stat-info p {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0;
    }

    .stat-icon {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
    }

    .bg-blue-soft {
        background: rgba(0, 113, 133, 0.1);
        color: var(--primary-color);
    }

    .bg-gold-soft {
        background: rgba(247, 202, 0, 0.15);
        color: #d4a000;
    }

    .bg-green-soft {
        background: rgba(0, 118, 0, 0.1);
        color: var(--success);
    }

    /* ===== SECTIONS & TABLES ===== */
    .dashboard-section {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 25px;
        height: 100%;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border-color);
    }

    .admin-table th {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--text-muted);
        padding: 12px 10px;
        border-bottom: 2px solid var(--border-color);
    }

    .admin-table td {
        padding: 15px 10px;
        border-bottom: 1px solid var(--border-color);
        font-size: 0.95rem;
    }
</style>

<div class="dashboard-wrapper">
    <!-- LOW STOCK ALERT -->
    @if (Model.LowStockCount > 0)
    {
        <div class="alert alert-warning">
            <strong>⚠ Low Stock Alert!</strong>
            You have @Model.LowStockCount product(s) with low inventory.
        </div>
    }

    <div class="dashboard-header">
        <h1 class="dash-title"><i class="fas fa-store text-primary"></i> Seller Dashboard</h1>
        <div class="dash-actions">
            <a asp-controller="Seller" asp-action="Orders" class="dash-btn">
                <i class="fas fa-receipt"></i> Orders
            </a>
            <a asp-controller="Seller" asp-action="Products" class="dash-btn dash-btn-primary">
                <i class="fas fa-box"></i> Manage Products
            </a>
        </div>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-info">
                <h3>Products</h3>
                <p>@Model.Product.Count</p>
            </div>
            <div class="stat-icon bg-blue-soft"><i class="fas fa-boxes"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Orders</h3>
                <p>@Model.Orders.Count</p>
            </div>
            <div class="stat-icon bg-blue-soft"><i class="fas fa-shopping-cart"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Revenue</h3>
                <p>₹@Model.Revenue.ToString("N0")</p>
            </div>
            <div class="stat-icon bg-gold-soft"><i class="fas fa-indian-rupee-sign"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Profit</h3>
                <p>₹@Model.Profit.ToString("N0")</p>
            </div>
            <div class="stat-icon bg-green-soft"><i class="fas fa-chart-line"></i></div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="dashboard-section">
                <h3 class="section-title">Top Selling Products</h3>
                <div class="table-responsive">
                    <table class="table admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Product Name</th>
                                <th class="text-end">Sold</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopProducts != null && Model.TopProducts.Any())
                            {
                                foreach (var p in Model.TopProducts.Take(5))
                                {
                                    <tr>
                                        <td>@p.TopProductName</td>
                                        <td class="text-end">@p.TotalSold</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" class="text-center text-muted py-4">No data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="dashboard-section">
                <h3 class="section-title">Recent Orders</h3>
                <div class="table-responsive">
                    <table class="table admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Order Date</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Recentorders != null && Model.Recentorders.Any())
                            {
                                foreach (var o in Model.Recentorders.Take(5))
                                {
                                    <tr>
                                        <td class="fw-bold">@o.ProductName</td>
                                        <td class="text-muted"><i class="far fa-calendar-alt me-1"></i> @o.OrderDate.ToString("dd MMM yyyy")</td>
                                        <td class="text-end fw-bold" style="color: var(--danger);">₹@o.Amount.ToString("N0")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-4">No recent orders</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>