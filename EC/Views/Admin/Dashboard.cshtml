@model EC.Models.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary-color: #007185;
        --secondary-color: #f7ca00;
        --secondary-hover: #e0b700;
        --text-main: #0F1111;
        --text-muted: #565959;
        --bg-light: #f3f3f3;
        --white: #ffffff;
        --border-color: #e7e7e7;
        --success: #007600;
    }

    body {
        background: var(--bg-light);
        font-family: "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: var(--text-main);
    }

    .admin-dashboard {
        padding: 40px 15px;
        max-width: 1300px;
        margin: 0 auto;
    }

    /* ===== HEADER & ACTIONS ===== */
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .dash-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-main);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .dash-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .dash-btn {
        background: var(--white);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.2s;
        box-shadow: 0 2px 5px rgba(213,217,217,0.3);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .dash-btn:hover {
            background: var(--bg-light);
            border-color: #d1d1d1;
            color: var(--primary-color);
        }

    .dash-btn-primary {
        background: var(--secondary-color);
        border-color: transparent;
    }

        .dash-btn-primary:hover {
            background: var(--secondary-hover);
            color: var(--text-main);
        }

    /* ===== SUMMARY CARDS ===== */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 25px 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        transition: transform 0.2s, box-shadow 0.2s;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.05);
        }

    .stat-info h3 {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-muted);
        margin: 0 0 8px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-info p {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-main);
        margin: 0;
        line-height: 1;
    }

    .stat-icon {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .icon-blue {
        background: rgba(0, 113, 133, 0.1);
        color: var(--primary-color);
    }

    .icon-gold {
        background: rgba(247, 202, 0, 0.2);
        color: #d4a000;
    }

    .icon-green {
        background: rgba(0, 118, 0, 0.1);
        color: var(--success);
    }

    .icon-gray {
        background: #f0f2f2;
        color: var(--text-muted);
    }

    /* ===== DASHBOARD SECTIONS (Charts & Tables) ===== */
    .dashboard-section {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        height: 100%;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border-color);
    }

    /* ===== TABLES ===== */
    .admin-table th {
        background: transparent;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--text-muted);
        border-bottom: 2px solid var(--border-color);
        padding: 12px 10px;
    }

    .admin-table td {
        vertical-align: middle;
        padding: 15px 10px;
        border-bottom: 1px solid var(--border-color);
        font-size: 0.95rem;
    }

    .fw-medium {
        font-weight: 600;
    }
</style>

<div class="admin-dashboard">

    <div class="dashboard-header">
        <h1 class="dash-title"><i class="fas fa-chart-line text-primary"></i> Admin Dashboard</h1>
        <div class="dash-actions">
            <a class="dash-btn" href="/Admin/UserList"><i class="fas fa-users"></i> Users</a>
            <a class="dash-btn" href="/Admin/Orders"><i class="fas fa-receipt"></i> Orders</a>
            <a class="dash-btn dash-btn-primary" href="/Admin/Products"><i class="fas fa-plus"></i> Manage Products</a>
        </div>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Products</h3>
                <p>@Model.ProductCount</p>
            </div>
            <div class="stat-icon icon-blue"><i class="fas fa-box-open"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Orders</h3>
                <p>@Model.OrderCount</p>
            </div>
            <div class="stat-icon icon-gray"><i class="fas fa-shopping-bag"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Users</h3>
                <p>@Model.UserCount</p>
            </div>
            <div class="stat-icon icon-blue"><i class="fas fa-user-friends"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Revenue</h3>
                <p>₹@Model.Revenue.ToString("N0")</p>
            </div>
            <div class="stat-icon icon-gold"><i class="fas fa-rupee-sign"></i></div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>Profit</h3>
                <p>₹@Model.Profit.ToString("N0")</p>
            </div>
            <div class="stat-icon icon-green"><i class="fas fa-arrow-trend-up"></i></div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="dashboard-section">
                <h3 class="section-title">Monthly Revenue & Profit</h3>
                <canvas id="revenueChart" height="100"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="dashboard-section">
                <h3 class="section-title">Monthly Orders</h3>
                <canvas id="ordersChart" height="220"></canvas>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-lg-5">
            <div class="dashboard-section">
                <h3 class="section-title">Top Selling Products</h3>
                <div class="table-responsive">
                    <table class="table admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Product Name</th>
                                <th class="text-end">Total Sold</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopProducts != null && Model.TopProducts.Any())
                            {
                                foreach (var p in Model.TopProducts.Take(5))
                                {
                                    <tr>
                                        <td class="fw-medium text-primary">@p.Name</td>
                                        <td class="text-end fw-bold">@p.Total</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" class="text-center text-muted py-4">No data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="dashboard-section">
                <h3 class="section-title">Recent Orders</h3>
                <div class="table-responsive">
                    <table class="table admin-table mb-0">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Order Date</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentOrders != null && Model.RecentOrders.Any())
                            {
                                foreach (var o in Model.RecentOrders.Take(5))
                                {
                                    <tr>
                                        <td class="fw-medium">@o.ProductName</td>
                                        <td class="text-muted"><i class="far fa-calendar-alt me-1"></i> @o.OrderDate.ToString("dd MMM yyyy")</td>
                                        <td class="text-end fw-bold" style="color: #B12704;">₹@o.Amount.ToString("N0")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-4">No recent orders</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const revenueData = @Html.Raw(JsonSerializer.Serialize(Model.MonthlyRevenue));
    const profitData = @Html.Raw(JsonSerializer.Serialize(Model.MonthlyProfit));
    const ordersData = @Html.Raw(JsonSerializer.Serialize(Model.MonthlyOrders));

    // Revenue & Profit Chart (Updated to Brand Colors)
    new Chart(document.getElementById('revenueChart'), {
        type: 'line',
        data: {
            labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
            datasets: [
                {
                    label: 'Revenue',
                    data: revenueData,
                    borderColor: '#007185',
                    backgroundColor: 'rgba(0, 113, 133, 0.1)',
                    fill: true,
                    tension: 0.3
                },
                {
                    label: 'Profit',
                    data: profitData,
                    borderColor: '#007600',
                    backgroundColor: 'rgba(0, 118, 0, 0.1)',
                    fill: true,
                    tension: 0.3
                }
            ]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'top' } },
            scales: { y: { beginAtZero: true } }
        }
    });

    // Orders Chart (Updated to Brand Colors)
    new Chart(document.getElementById('ordersChart'), {
        type: 'bar',
        data: {
            labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
            datasets: [{
                label: 'Orders',
                data: ordersData,
                backgroundColor: '#f7ca00',
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true } }
        }
    });
</script>