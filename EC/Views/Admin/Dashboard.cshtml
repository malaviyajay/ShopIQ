@model EC.Models.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<style>
    body {
        background: #f9fafb;
    }

    .dashboard {
        padding: 40px 30px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .dash-title {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 30px;
        color: #111827;
    }

    .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 25px;
    }

    .dash-card {
        background: linear-gradient(135deg, #ffffff, #f3f4f6);
        border-radius: 16px;
        padding: 30px 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .dash-card::before {
            content: "";
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: rgba(79,70,229,0.05);
            transform: rotate(45deg);
        }

        .dash-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
        }

        .dash-card h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 10px;
            color: #6b7280;
            z-index: 1;
            position: relative;
        }

        .dash-card p {
            font-size: 28px;
            font-weight: 700;
            color: #4f46e5;
            margin: 0;
            z-index: 1;
            position: relative;
        }

    .dash-actions {
        margin-top: 40px;
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .dash-btn {
        padding: 14px 22px;
        border-radius: 12px;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #fff;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        box-shadow: 0 6px 16px rgba(99,102,241,0.4);
        transition: all 0.25s ease-in-out;
    }

        .dash-btn:hover {
            background: linear-gradient(135deg, #5145cd, #4338ca);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(79,70,229,0.5);
        }

    /* Responsive typography for smaller screens */
    .media (max-width: 768px) {
        .dash-title {
            font-size: 24px;
        }

        .dash-card p {
            font-size: 24px;
        }

        .dash-card h3 {
            font-size: 15px;
        }

        .dash-btn {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="dashboard">
    <div class="dash-title">    Admin Dashboard</div>

    <div class="card-grid">
        <div class="dash-card">
            <h3>Total Products</h3>
            <p>@Model.ProductCount</p>
        </div>

        <div class="dash-card">
            <h3>Total Orders</h3>
            <p>@Model.OrderCount</p>
        </div>

        <div class="dash-card">
            <h3>Total Users</h3>
            <p>@Model.UserCount</p>
        </div>

        <div class="dash-card">
            <h3>Revenue</h3>
            <p>₹@Model.Revenue.ToString("N0")</p>
        </div>
    </div>

    <div class="dash-actions">
        <a class="dash-btn" href="/Admin/Products">📦 Manage Products</a>
        <a class="dash-btn" href="/Admin/Orders">🧾 Orders</a>
        <a class="dash-btn" href="/Admin/Userlist">👤 Users</a>
    </div>
</div>
