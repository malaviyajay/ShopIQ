@model List<EC.Models.Product>
@{
    ViewData["Title"] = "Manage Products";
    Layout = "_Layout";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary: #0d6efd;
        --bg: #f4f6f9;
        --white: #fff;
        --border: #e5e7eb;
        --text: #333;
        --muted: #777;
        --danger: #dc3545;
    }

    body {
        background: var(--bg);
        font-family: 'Segoe UI', sans-serif;
    }

    .container-box {
        max-width: 1400px;
        margin: auto;
        padding: 30px;
    }

    /* HEADER */
    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

    .title {
        font-size: 26px;
        font-weight: 700;
    }

    .btn-add {
        background: var(--primary);
        color: white;
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        display: flex;
        gap: 8px;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

        .btn-add:hover {
            background: #0b5ed7;
        }

    /* CARD */
    .card-box {
        background: var(--white);
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        padding: 20px;
    }

    /* SEARCH */
    .search-box {
        position: relative;
        max-width: 350px;
        margin-bottom: 15px;
    }

        .search-box i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
        }

        .search-box input {
            width: 100%;
            padding: 10px 12px 10px 35px;
            border-radius: 8px;
            border: 1px solid var(--border);
            outline: none;
        }

            .search-box input:focus {
                border-color: var(--primary);
            }

    /* TABLE */
    .table-modern {
        width: 100%;
        border-collapse: collapse;
    }

        .table-modern thead {
            background: #f8fafc;
        }

        .table-modern th {
            text-align: left;
            font-size: 12px;
            text-transform: uppercase;
            color: var(--muted);
            padding: 14px 10px;
            border-bottom: 1px solid var(--border);
        }

        .table-modern td {
            padding: 14px 10px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .table-modern tbody tr {
            transition: 0.2s;
        }

            .table-modern tbody tr:hover {
                background: #f1f5f9;
            }

    /* BADGES */
    .price {
        font-weight: bold;
        color: #dc3545;
    }

    .category {
        background: #eef2ff;
        color: #4f46e5;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
    }

    /* ACTION */
    .btn-delete {
        background: transparent;
        border: 1px solid var(--danger);
        color: var(--danger);
        padding: 6px 10px;
        border-radius: 6px;
        font-size: 13px;
        cursor: pointer;
    }

        .btn-delete:hover {
            background: var(--danger);
            color: white;
        }

    /* BACK */
    .btn-back {
        margin-top: 20px;
        display: inline-block;
        padding: 10px 18px;
        border-radius: 50px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: var(--text);
    }

        .btn-back:hover {
            background: white;
        }

</style>

<div class="container-box">

    <!-- HEADER -->
    <div class="header">
        <h1 class="title"><i class="fas fa-boxes"></i> Inventory Management</h1>
        <a href="/Admin/Add" class="btn-add">
            <i class="fas fa-plus"></i> Add Product
        </a>
    </div>

    <!-- CARD -->
    <div class="card-box">

        <!-- SEARCH -->
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input id="productSearch" type="text" placeholder="Search products..." />
        </div>

        <!-- TABLE -->
        <table class="table-modern">
            <thead>
                <tr>
                    <th>Product Name</th>
                    <th>Price</th>
                    <th>Category</th>
                    <th style="width:150px;">Action</th>
                </tr>
            </thead>

            <tbody id="productTable">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" style="text-align:center; padding:30px;">
                            No products found
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var p in Model)
                    {
                        <tr>
                            <td><strong>@p.Name</strong></td>

                            <td>
                                <span class="price">₹@p.Price</span>
                            </td>

                            <td>
                                <span class="category">@p.CategoryId</span>
                            </td>

                            <td>
                                <form asp-controller="Admin" asp-action="Delete" asp-route-id="@p.Id" method="post">
                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn-delete"
                                            onclick="return confirm('Delete this product?')">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <button class="btn-back" onclick="history.back()">
        ← Back
    </button>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const input = document.getElementById("productSearch");
        const rows = document.querySelectorAll("#productTable tr");

        input.addEventListener("keyup", function () {
            let filter = input.value.toLowerCase();

            rows.forEach(row => {
                if (row.cells.length === 1) return;

                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? "" : "none";
            });
        });
    });
</script>