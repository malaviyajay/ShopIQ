@model EC.Models.Product

@{
    ViewData["Title"] = "Add Product";
}

<style>
    body {
        background: #f3f4f6;
    }

    .add-wrapper {
        max-width: 700px;
        margin: 50px auto;
        padding: 0 15px;
    }

    .add-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 35px 30px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

        .add-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 40px rgba(0,0,0,0.12);
        }

    .add-title {
        font-size: 26px;
        font-weight: 700;
        margin-bottom: 30px;
        color: #111827;
        text-align: center;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 6px;
        color: #374151;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 14px;
        border: 1px solid #d1d5db;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.2s ease-in-out;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
            outline: none;
        }

    /* Buttons */
    .btn-ec, .btn-back {
        padding: 14px 24px;
        font-size: 15px;
        font-weight: 600;
        border-radius: 12px;
        border: none;
        cursor: pointer;
        transition: all 0.25s ease-in-out;
        box-shadow: 0 6px 16px rgba(79,70,229,0.35);
        text-align: center;
        display: inline-block;
        margin-top: 10px;
    }

    .btn-ec {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #fff;
        margin-right: 12px;
    }

        .btn-ec:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99,102,241,0.45);
            opacity: 0.95;
        }

    .btn-back {
        background: linear-gradient(135deg, #6b5dfc, #5145cd);
        color: #fff;
    }

        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(79,70,229,0.45);
            opacity: 0.95;
        }

    /* Responsive */
    .media (max-width: 768px) {
        .add-card {
            padding: 30px 20px;
        }

        .btn-ec, .btn-back {
            width: 100%;
            margin-right: 0;
        }
    }
</style>

<div class="add-wrapper">
    <div class="add-card">
        <div class="add-title">➕ Add New Product</div>

        <form asp-action="Add" method="post">

            <div class="mb-3">
                <label class="form-label">Product Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter product name" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Price (₹)</label>
                <input asp-for="Price" class="form-control" placeholder="Enter price" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Image URL</label>
                <input asp-for="Image" class="form-control" placeholder="https://example.com/product.jpg" required />
            </div>

            <div class="mb-4">
                <label class="form-label">Category</label>
                <select asp-for="CategoryId" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))" class="form-control" required>
                    <option value="">-- Select Category --</option>
                </select>
            </div>

            <button type="submit" class="btn-ec">💾 Add Product</button>
            <button type="button" class="btn-back" onclick="history.back();">← Go Back</button>
        </form>
    </div>
</div>
