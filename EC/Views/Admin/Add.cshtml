@model EC.Models.Product

@{
    ViewData["Title"] = "Add Product";
    Layout = "_Layout";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary: #0d6efd;
        --bg: #f4f6f9;
        --white: #fff;
        --border: #e5e7eb;
        --text: #333;
        --muted: #777;
    }

    body {
        background: var(--bg);
        font-family: 'Segoe UI', sans-serif;
    }

    .page-container {
        max-width: 1200px;
        margin: auto;
        padding: 30px;
    }

    /* HEADER */
    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

    .dash-title {
        font-size: 26px;
        font-weight: 700;
    }

    /* CARD */
    .card-box {
        background: var(--white);
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        padding: 30px;
        max-width: 700px;
        margin: auto;
    }

    .section-title {
        font-weight: 700;
        margin-bottom: 20px;
        font-size: 18px;
    }

    /* FORM */
    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 6px;
        display: block;
        color: var(--text);
    }

    .form-control-custom {
        width: 100%;
        padding: 10px 12px;
        border-radius: 8px;
        border: 1px solid var(--border);
        font-size: 14px;
        outline: none;
    }

        .form-control-custom:focus {
            border-color: var(--primary);
        }

    /* QUANTITY */
    .qty-box {
        display: flex;
        align-items: center;
    }

    .qty-btn {
        width: 40px;
        height: 40px;
        border: 1px solid var(--border);
        background: #f1f5f9;
        cursor: pointer;
    }

    .qty-input {
        width: 70px;
        height: 40px;
        text-align: center;
        border: 1px solid var(--border);
        border-left: none;
        border-right: none;
    }

    /* BUTTONS */
    .btn-primary-custom {
        background: var(--primary);
        color: white;
        padding: 10px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        width: 100%;
    }

        .btn-primary-custom:hover {
            background: #0b5ed7;
        }

    .btn-secondary-custom {
        margin-top: 10px;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: white;
        width: 100%;
    }

</style>

<div class="page-container">

    <!-- HEADER -->
    <div class="dashboard-header">
        <h1 class="dash-title"><i class="fas fa-plus"></i> Add Product</h1>
    </div>

    <!-- CARD -->
    <div class="card-box">

        <h5 class="section-title">Product Details</h5>

        <form asp-action="Add" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Product Name</label>
                <input asp-for="Name" class="form-control-custom" required />
            </div>

            <div class="row">
                <div class="col-md-6 form-group">
                    <label class="form-label">Price (₹)</label>
                    <input asp-for="Price" type="number" class="form-control-custom" required />
                </div>

                <div class="col-md-6 form-group">
                    <label class="form-label">Category</label>
                    <select asp-for="CategoryId"
                            asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))"
                            class="form-control-custom"
                            required>
                        <option value="">Select Category</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Image File Name</label>
                <input asp-for="Image" class="form-control-custom" required />
            </div>

            <div class="form-group">
                <label class="form-label">Quantity</label>

                <div class="qty-box">
                    <button type="button" class="qty-btn" onclick="changeQuantity(-1)">-</button>

                    <input id="quantity-input" name="Quantity"
                           class="qty-input"
                           type="number"
                           value="1"
                           min="1" />

                    <button type="button" class="qty-btn" onclick="changeQuantity(1)">+</button>
                </div>
            </div>

            <button type="submit" class="btn-primary-custom">
                Add Product
            </button>

            <button type="button" class="btn-secondary-custom" onclick="history.back();">
                Cancel
            </button>

        </form>
    </div>

</div>

<script>
    function changeQuantity(delta) {
        const qtyInput = document.getElementById('quantity-input');
        let current = parseInt(qtyInput.value) || 1;

        current += delta;
        if (current < 1) current = 1;

        qtyInput.value = current;
    }
</script>