@model EC.Models.Product
@{
    ViewData["Title"] = "Edit Product";
    Layout = "_Layout";
}

<style>
    body {
        background: #f3f4f6;
    }

    .edit-product-container {
        max-width: 650px;
        margin: 50px auto;
        background: #ffffff;
        padding: 40px 30px;
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .edit-product-container:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 40px rgba(0,0,0,0.12);
    }

    .edit-product-container h2 {
        text-align: center;
        margin-bottom: 35px;
        font-weight: 700;
        font-size: 26px;
        color: #111827;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
        color: #374151;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 14px;
        border: 1px solid #d1d5db;
        font-size: 14px;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.2s ease-in-out;
    }

    .form-control:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79,70,229,0.15);
        outline: none;
    }

    /* Update Button */
    .btn-update {
        width: 100%;
        padding: 14px;
        border-radius: 14px;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #fff;
        font-size: 16px;
        font-weight: 600;
        margin-top: 20px;
        border: none;
        cursor: pointer;
        box-shadow: 0 6px 16px rgba(79,70,229,0.35);
        transition: all 0.25s ease-in-out;
    }

    .btn-update:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(79,70,229,0.45);
        opacity: 0.95;
    }

    /* Back Button */
    .btn-back {
        display: block;
        width: 100%;
        margin-top: 15px;
        padding: 14px;
        border-radius: 14px;
        background: linear-gradient(135deg, #6b5dfc, #5145cd);
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        box-shadow: 0 6px 16px rgba(79,70,229,0.35);
        transition: all 0.25s ease-in-out;
    }

    .btn-back:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(79,70,229,0.45);
        opacity: 0.95;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .edit-product-container {
            padding: 30px 20px;
        }
        .btn-update, .btn-back {
            font-size: 15px;
        }
    }
</style>

<div class="edit-product-container">
    <h2>✏️ Edit Product</h2>

    <form method="post">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Product Name</label>
            <input asp-for="Name" class="form-control" placeholder="Enter product name" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Price (₹)</label>
            <input asp-for="Price" class="form-control" placeholder="Enter price" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>
            <select asp-for="CategoryId" class="form-control" required>
                <option value="">-- Select Category --</option>
                @foreach (var c in ViewBag.Categories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Image URL</label>
            <input asp-for="Image" class="form-control" placeholder="https://example.com/product.jpg" required />
        </div>

        <button type="submit" class="btn-update">💾 Update Product</button>
        <button type="button" class="btn-back" onclick="history.back();">← Go Back</button>
    </form>
</div>
