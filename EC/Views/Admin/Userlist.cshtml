@model List<EC.Models.User>
@{
    ViewData["Title"] = "User List";
    Layout = "_Layout";
}

<style>

    body {
        background: #eaeded;
        font-family: Arial, Helvetica, sans-serif;
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    /* ===== CARD ===== */
    .card-box {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 20px;
    }

    /* ===== TABLE ===== */
    table.custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        table.custom-table thead {
            background: #f3f3f3;
        }

        table.custom-table th {
            padding: 14px;
            text-align: left;
            font-size: 13px;
            color: #555;
            text-transform: uppercase;
        }

        table.custom-table td {
            padding: 14px;
            border-top: 1px solid #eee;
            font-size: 14px;
        }

        table.custom-table tbody tr:hover {
            background: #fafafa;
        }

    /* ===== SELECT ===== */
    select.form-select {
        border-radius: 6px;
        border: 1px solid #ccc;
        padding: 5px 10px;
        font-size: 13px;
        background: #fff;
    }

    /* ===== AMAZON BUTTON ===== */
    .btn-update {
        background: #ffd814;
        border: 1px solid #fcd200;
        color: #111;
        border-radius: 6px;
        padding: 6px 14px;
        font-weight: 600;
        font-size: 13px;
    }

        .btn-update:hover {
            background: #f7ca00;
        }

    .btn-back {
        background: #ffd814;
        border: 1px solid #fcd200;
        color: #111;
        border-radius: 6px;
        padding: 8px 18px;
        font-weight: 600;
        margin-top: 18px;
    }

        .btn-back:hover {
            background: #f7ca00;
        }

</style>

<h2 class="page-title">Users</h2>

<div class="card-box">

    <table class="custom-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                  

                            <td>
                            <form asp-action="UpdateUserRole"asp-controller="Admin"method="post"style="display:flex; gap:10px;">

                                <input type="hidden" name="userId" value="@user.Id" />
                            <select name="roleId" required>
                                <option disabled selected>-- Select Role --</option>
                                <option value="1">Admin</option>
                                <option value="2">Seller</option>
                                <option value="3">Customer</option>
                            </select>

                                <button type="submit" class="btn-update">
                                    Update
                                </button>
                            </form>
                        </td>
                  </tr>
            }
        </tbody>

    </table>

    <button type="button" class="btn-back" onclick="history.back();">
        ← Go Back
    </button>

</div>
