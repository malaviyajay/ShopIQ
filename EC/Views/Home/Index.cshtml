@model List<EC.Models.Product>

@{
    ViewBag.Title = "Home";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary-color: #007185;
        --secondary-color: #f7ca00;
        --secondary-hover: #e0b700;
        --text-main: #0F1111;
        --text-muted: #565959;
        --bg-light: #f3f3f3;
        --white: #ffffff;
        --danger: #CC0C39;
        --border-color: #e7e7e7;
    }

    body {
        background-color: var(--bg-light);
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        color: var(--text-main);
        margin: 0;
    }

    /* HERO */
    .hero-container {
        position: relative;
        background: linear-gradient(to bottom, rgba(15,17,17,0.7), rgba(15,17,17,0.2)), url('https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&q=80&w=2070');
        background-size: cover;
        background-position: center;
        height: 450px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        margin-bottom: 2rem;
    }

    .hero-content {
        color: white;
        max-width: 800px;
        padding: 0 20px;
    }

        .hero-content h1 {
            font-size: 3.2rem;
            font-weight: 800;
        }

    .btn-hero {
        background: var(--secondary-color);
        padding: 14px 40px;
        border-radius: 50px;
        font-weight: 700;
        text-decoration: none;
        color: #000;
    }

    /* PRODUCT CARD */
    .product-card {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 20px;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .img-wrapper {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 15px;
        position: relative;
    }

    .product-img {
        max-height: 100%;
        max-width: 100%;
        object-fit: contain;
    }

    .discount-badge {
        color: white;
        font-size: 0.75rem;
        padding: 5px 10px;
        border-radius: 4px;
        position: absolute;
        top: 0;
        left: 0;
        font-weight: 600;
    }

    .badge-discount {
        background: var(--danger);
    }

    .badge-out {
        background: #232f3e; /* STEP 4: Dark badge for Out of Stock */
    }

    .product-name {
        font-weight: 600;
        margin-bottom: 10px;
        height: 40px;
        overflow: hidden;
        color: var(--text-main);
    }

    .price-current {
        font-size: 1.4rem;
        font-weight: 700;
    }

    .price-old {
        text-decoration: line-through;
        color: var(--text-muted);
        margin-left: 6px;
    }

    .card-footer-custom {
        margin-top: auto;
    }

    .action-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 10px;
    }

    .btn-view {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: center;
        text-decoration: none;
        color: black;
        border-radius: 6px;
    }

    .btn-add-cart {
        background: var(--secondary-color);
        padding: 8px;
        text-align: center;
        text-decoration: none;
        color: black;
        border-radius: 6px;
        font-weight: 600;
    }

</style>

<div class="hero-container">
    <div class="hero-content">
        <h1>Welcome to EC Shop</h1>
        <p>Your one-stop destination for the latest products.</p>
        <a asp-controller="Product" asp-action="Index" class="btn-hero">
            Explore Products
        </a>
    </div>
</div>

<div class="container pb-5">

    @if (Model == null || !Model.Any())
    {
        <div class="text-center bg-white p-5 rounded shadow-sm">
            <h3>No products available</h3>
        </div>
    }
    else
    {
        
    }
    {
        <div class="row g-4">
            @foreach (var p in Model)
            {
                var discount = 15;
                var oldPrice = p.Price + (p.Price * discount / 100);
                bool isOutOfStock = p.Quantity <= 0;

                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6">
                    <div class="product-card">

                        <div class="img-wrapper">

                            @if (isOutOfStock)
                            {
                                <span class="discount-badge badge-out">
                                    OUT OF STOCK
                                </span>
                            }
                            else
                            {
                                <span class="discount-badge badge-discount">
                                    @discount% OFF
                                </span>
                            }

                            <img src="@Url.Content("~/images/products/" + p.Image)"
                                 alt="@p.Name"
                                 class="product-img"
                                 onerror="this.src='https://via.placeholder.com/250?text=Product'" />
                        </div>

                        <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id" class="text-decoration-none">
                            <div class="product-name">@p.Name</div>
                        </a>

                        <div class="card-footer-custom">

                            <div>
                                <span class="price-current">₹@p.Price</span>
                                <span class="price-old">₹@oldPrice</span>
                            </div>

                            @if (isOutOfStock)
                            {
                                <div class="text-danger fw-bold mt-1">
                                    Out of Stock
                                </div>
                            }
                            else
                            {
                                <div class="text-success fw-bold mt-1">
                                    In Stock (@p.Quantity left)
                                </div>
                            }

                            <div class="action-buttons">

                                <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id" class="btn-view">
                                    Details
                                </a>

                                @if (isOutOfStock)
                                {
                                    <button class="btn-add-cart"disabled    style="background:#ccc;cursor:not-allowed;">
                                        Out of Stock
                                    </button>
                                }
                                else
                                {
                                    <a asp-controller="Cart"asp-action="AddToCart"asp-route-id="@p.Id"class="btn-add-cart">
                                        Add to Cart
                                    </a>
                                }

                            </div>

                        </div>

                    </div>
                </div>
            }
        </div>
    }

</div>