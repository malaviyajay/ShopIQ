<!-- ===== PRODUCTS SECTION ===== -->
<div class="products-section">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-dark">
            No products available right now.
        </div>
    }
    else
    {
        <!-- BEST DEALS -->
        <div class="mb-4">
            <h4 class="section-title">Best Deals</h4>
            <div class="row g-4">
                @foreach (var p in Model.Take(6))
                {
                    var discount = 15;
                    var oldPrice = p.Price + (p.Price * discount / 100);

                    <div class="col-lg-4 col-md-6">
                        <div class="card product-card p-3 text-center">
                            <span class="discount-badge">@discount% OFF</span>
                            <img src="@Url.Content("~/images/products/" + p.Image)"
                                 class="product-img mb-3"
                                 alt="@p.Name" />


                            <h6 class="fw-semibold">@p.Name</h6>
                            <p>
                                <span class="price">₹@p.Price</span>
                                <span class="old-price">₹@oldPrice</span>
                            </p>
                            <div class="d-grid gap-2">
                                <a asp-controller="Product"asp-action="Details"asp-route-id="@p.Id"
                                   class="btn btn-outline-primary btn-sm btn-rounded">
                                    View
                                </a>

                                <a asp-controller="Cart"asp-action="AddToCart"asp-route-id="@p.Id"
                                   class="btn btn-success btn-sm btn-rounded">
                                    Add to Cart
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- NEW ARRIVALS -->
        <div class="mb-4">
            <h4 class="section-title">New Arrivals</h4>
            <div class="row g-4">
                @foreach (var p in Model.Skip(6).Take(6))
                {
                    var discount = 10;
                    var oldPrice = p.Price + (p.Price * discount / 100);

                    <div class="col-lg-4 col-md-6">
                        <div class="card product-card p-3 text-center">
                            <span class="discount-badge">@discount% OFF</span>
                            <img src="@p.Image" class="product-img mb-3" />
                            <h6 class="fw-semibold">@p.Name</h6>
                            <p>
                                <span class="price">₹@p.Price</span>
                                <span class="old-price">₹@oldPrice</span>
                            </p>
                            <div class="d-grid gap-2">
                                <a asp-controller="Product"asp-action="Details"asp-route-id="@p.Id"class="btn btn-outline-primary btn-sm btn-rounded">
                                    View
                                </a>

                                <a asp-controller="Cart"asp-action="AddToCart"asp-route-id="@p.Id"class="btn btn-success btn-sm btn-rounded">
                                    Add to Cart
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
