@model List<EC.Models.Product>

@{
    ViewBag.Title = "Home";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary-color: #007185;
        --secondary-color: #f7ca00;
        --secondary-hover: #e0b700;
        --text-main: #0F1111;
        --text-muted: #565959;
        --bg-light: #f3f3f3;
        --white: #ffffff;
        --danger: #CC0C39;
        --border-color: #e7e7e7;
    }

    body {
        background-color: var(--bg-light);
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        color: var(--text-main);
        margin: 0;
    }

    /* --- HERO SECTION --- */
    .hero-container {
        position: relative;
        background: linear-gradient(to bottom, rgba(0,0,0,0.6), rgba(0,0,0,0.2)), 
                    url('https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&q=80&w=2070');
        background-size: cover;
        background-position: center;
        height: 400px; /* Perfect height for desktop/mobile balance */
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .hero-content {
        color: white;
        max-width: 800px;
        padding: 0 20px;
    }

    .hero-content h1 {
        font-size: clamp(2rem, 5vw, 3.2rem); /* Responsive font size */
        font-weight: 800;
        margin-bottom: 1rem;
        text-shadow: 0 2px 10px rgba(0,0,0,0.3);
    }

    .btn-hero {
        background: var(--secondary-color);
        padding: 12px 35px;
        border-radius: 8px;
        font-weight: 700;
        text-decoration: none;
        color: #000;
        display: inline-block;
        transition: background 0.2s;
    }

    .btn-hero:hover {
        background: var(--secondary-hover);
        color: #000;
    }

    /* --- LAYOUT WRAPPER --- */
    .shop-container {
        max-width: 1440px; /* Prevents cards from getting too wide on huge monitors */
        margin: 0 auto;
        padding: 0 20px;
    }

    /* --- PRODUCT CARD --- */
    .product-card {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 15px;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .product-card:hover {
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .img-wrapper {
        height: 200px; /* Fixed height ensures row alignment */
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
        position: relative;
        overflow: hidden;
    }

    .product-img {
        max-height: 100%;
        max-width: 100%;
        object-fit: contain;
        transition: transform 0.3s;
    }

    .product-card:hover .product-img {
        transform: scale(1.05);
    }

    .discount-badge {
        color: white;
        font-size: 0.7rem;
        padding: 4px 8px;
        border-radius: 3px;
        position: absolute;
        top: 0;
        left: 0;
        font-weight: 700;
        z-index: 1;
    }

    .badge-discount { background: var(--danger); }
    .badge-out { background: #232f3e; }

    .product-name {
        font-weight: 600;
        font-size: 0.95rem;
        line-height: 1.3;
        margin-bottom: 8px;
        height: 2.6em; /* Forces exactly 2 lines height for alignment */
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        color: var(--text-main);
    }

    .price-current {
        font-size: 1.3rem;
        font-weight: 700;
        color: #000;
    }

    .price-old {
        text-decoration: line-through;
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-left: 6px;
    }

    .stock-info {
        font-size: 0.85rem;
        margin: 5px 0 15px 0;
    }

    .card-footer-custom {
        margin-top: auto; /* Pushes buttons to the very bottom of the card */
    }

    .action-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .btn-view, .btn-add-cart {
        padding: 8px 5px;
        text-align: center;
        text-decoration: none;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-view {
        border: 1px solid #d5d9d9;
        color: #0F1111;
        background: white;
    }

    .btn-view:hover { background: #f7fafa; color: #000; }

    .btn-add-cart {
        background: var(--secondary-color);
        color: black;
        border: 1px solid #f2c200;
    }

    .btn-add-cart:hover {
        background: var(--secondary-hover);
        color: black;
    }

    .btn-disabled {
        background: #e7e9ec !important;
        border-color: #d5d9d9 !important;
        color: #888 !important;
        cursor: not-allowed;
    }
</style>

<div class="hero-container">
    <div class="hero-content">
        <h1>Welcome to EC Shop</h1>
        <p>Your one-stop destination for the latest products.</p>
        <a asp-controller="Product" asp-action="Index" class="btn-hero">
            Explore Products
        </a>
    </div>
</div>

<div class="shop-container pb-5">
    @if (Model == null || !Model.Any())
    {
        <div class="text-center bg-white p-5 rounded shadow-sm">
            <h3>No products available at the moment.</h3>
            <p class="text-muted">Please check back later!</p>
        </div>
    }
    else
    {
        <div class="row g-4"> @* g-4 provides consistent 24px spacing between cards *@
            @foreach (var p in Model)
            {
                var discount = 5;
                var oldPrice = p.Price + (p.Price * discount / 100);
                bool isOutOfStock = p.Quantity <= 0;

                <div class="col-xl-3 col-lg-4 col-md-6 col-6">
                    <div class="product-card">

                        <div class="img-wrapper">
                            @if (isOutOfStock)
                            {
                                <span class="discount-badge badge-out">OUT OF STOCK</span>
                            }
                            else
                            {
                                <span class="discount-badge badge-discount">@discount% OFF</span>
                            }
                            
                            <img src="@Url.Content("~/images/" + p.Image)" 
                                 alt="@p.Name" 
                                 class="product-img" 
                                 onerror="this.src='https://via.placeholder.com/200x200?text=No+Image';" />
                        </div>

                        <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id" class="text-decoration-none">
                            <div class="product-name">@p.Name</div>
                        </a>

                        <div class="card-footer-custom">
                            <div>
                                <span class="price-current">₹@p.Price</span>
                                <span class="price-old">₹@oldPrice</span>
                            </div>

                            <div class="stock-info @(isOutOfStock ? "text-danger" : "text-success") fw-bold">
                                @if (isOutOfStock)
                                {
                                    <span>Out of Stock</span>
                                }
                                else
                                {
                                    <span>In Stock (@p.Quantity left)</span>
                                }
                            </div>

                            <div class="action-buttons">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id" class="btn-view">
                                    Details
                                </a>

                                @if (isOutOfStock)
                                {
                                    <button class="btn-add-cart btn-disabled" disabled title="Product is currently unavailable">
                                        Sold Out
                                    </button>
                                }
                                else
                                {
                                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@p.Id" class="btn-add-cart">
                                        Add to Cart
                                    </a>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>