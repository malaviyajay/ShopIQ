@model EC.Models.ResetPasswordView
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Reset Password - ShopIQ</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Poppins', sans-serif;
            background: url('/images/bg.jpg') no-repeat center center/cover;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .card-auth {
            width: 420px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(14px);
            border-radius: 20px;
            padding: 50px 35px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.35);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #fff;
            animation: fadeIn 1s ease-in-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h4 {
            text-align: center;
            font-weight: 600;
            font-size: 24px;
            margin-bottom: 30px;
        }

        .form-control {
            border-radius: 12px;
            height: 50px;
            background: rgba(255, 255, 255, 0.85);
            border: none;
            padding: 0 15px;
            font-size: 16px;
            margin-bottom: 20px;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                outline: none;
                box-shadow: 0 0 10px rgba(124, 58, 237, 0.6);
            }

        .btn-main {
            background: linear-gradient(135deg, #6366f1, #7c3aed);
            border: none;
            color: #fff;
            height: 50px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .btn-main:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(124, 58, 237, 0.5);
            }

        .msg {
            color: #ffb3b3;
            text-align: center;
            margin-top: 15px;
            font-size: 14px;
        }

        .validation-summary-errors {
            color: #ffb3b3;
            margin-bottom: 15px;
            font-size: 14px;
        }

        .text-center a {
            color: #fff;
            font-weight: 500;
            text-decoration: underline; 
            transition: all 0.3s ease;
        }

            .text-center a:hover {
                color: #dcd6f7;
            }

        /* Small subtle icon */
        .lock-icon {
            display: block;
            margin: 0 auto 20px auto;
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.25);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 28px;
            color: #fff;
        }
    </style>
</head>

<body>
    <div class="card-auth">
        <span class="lock-icon">🔒</span>
        <h4>Reset Password</h4>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All"></div>

            <!-- Hidden Values -->
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <!-- Password Fields -->
            <input asp-for="NewPassword"type="password"class="form-control"placeholder="New Password" />

            <input asp-for="ConfirmPassword"type="password"class="form-control"placeholder="Confirm Password" />

            <button type="submit" class="btn-main w-100">Update Password</button>
            <div class="text-center mt-3 small">
                <a asp-action="Login">Back to Login</a>
            </div>
        </form>

        <div class="msg">@ViewBag.Msg</div>
    </div>
</body>
</html>
