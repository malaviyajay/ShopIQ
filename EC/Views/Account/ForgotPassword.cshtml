@model EC.Models.ForgotPasswordView
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ShopIQ - Forgot Password</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body class="d-flex justify-content-center align-items-center vh-100"
      style="background:url('/images/bg.jpg') no-repeat center center; background-size:cover; font-family:'Poppins',sans-serif;">

    <div class="card p-4 p-md-5 shadow-lg rounded-4 bg-white bg-opacity-25 border border-light border-opacity-25 text-white"
         style="backdrop-filter: blur(15px); max-width:400px; width:100%;">

        <div class="text-center mb-4">
            <h1 class="fw-bold">ShopIQ</h1>
            <p class="small mb-0">Reset your password</p>
        </div>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-warning small"></div>

            <div class="mb-3">
                <input asp-for="Email" class="form-control form-control-lg" placeholder="Enter Email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit"class="btn btn-primary w-100 btn-lg fw-bold"style="background: linear-gradient(135deg,#6366f1,#7c3aed); border:none;">
                Submit
            </button>
        </form>

        <div class="text-center mt-3 small">@ViewBag.Msg</div>

        <div class="text-center mt-3 small">
            <a asp-action="Login" asp-controller="Account"
               class="text-decoration-underline text-white">Back to Login</a>
        </div>

    </div>
</body>
</html>
