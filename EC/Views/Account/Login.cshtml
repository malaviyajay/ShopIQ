@model EC.Models.LoginVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login · EC</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

        body {
            margin: 0;
            height: 100vh;
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg,#6d28d9,#7c3aed,#4c1d95);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* MAIN CONTAINER */
        .login-card {
            width: 1000px;
            max-width: 95%;
            height: 600px;
            background: #f8fafc;
            border-radius: 30px;
            overflow: hidden;
            display: flex;
            box-shadow: 0 30px 70px rgba(0,0,0,.25);
        }

        /* LEFT ILLUSTRATION */
        .left-side {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #eef2ff;
        }

            .left-side img {
                width: 85%;
            }

        /* RIGHT FORM */
        .right-side {
            flex: 1;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        h2 {
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 25px;
        }

        .form-control {
            border: none;
            border-bottom: 2px solid #e2e8f0;
            border-radius: 0;
            background: transparent;
            padding-left: 0;
            margin-bottom: 20px;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #6d28d9;
            }

        .login-btn {
            background: linear-gradient(135deg,#6366f1,#7c3aed);
            border: none;
            padding: 12px;
            border-radius: 8px;
            color: white;
            font-weight: 600;
            margin-top: 10px;
            transition: .3s;
        }

            .login-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(124,58,237,.4);
            }

        .links {
            font-size: .85rem;
            color: #64748b;
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .register {
            text-align: center;
            font-size: .85rem;
            margin-top: 20px;
        }

        @@media(max-width:900px) {
            .left-side {
                display: none;
            }

            .login-card {
                height: auto;
            }
        }

    </style>
</head>

<body>

    <div class="login-card">

        <!-- LEFT IMAGE -->
        <div class="left-side">
            <img src="/images/login-illustration.png" />
        </div>

        <!-- RIGHT FORM -->
        <div class="right-side">

            <h2>Hello,<br />Welcome back</h2>

            <form method="post">
                @Html.AntiForgeryToken()

                <input asp-for="Email"
                       class="form-control"
                       placeholder="Username or email" />
                <span asp-validation-for="Email" class="text-danger small"></span>

                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="Password" />
                <span asp-validation-for="Password" class="text-danger small"></span>

                <div class="links">
                    <label>
                        <input type="checkbox" /> Remember me
                    </label>
                    <a href="#">Forgot password?</a>
                </div>

                <button type="submit" class="login-btn w-100">
                    Login
                </button>

            </form>

            <div class="register">
                Don't have an account?
                <a asp-action="Register">Click here</a>
            </div>

        </div>

    </div>

</body>
</html>
