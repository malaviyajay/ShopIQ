@model EC.Models.LoginVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ShopIQ</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="d-flex justify-content-center align-items-center vh-100"
      style="background: url('/images/bg.jpg') no-repeat center center; background-size: cover; font-family: 'Poppins', sans-serif;">

    <div class="card p-4 p-md-5 shadow-lg rounded-4 bg-white bg-opacity-25 border border-light border-opacity-25 text-white" style="backdrop-filter: blur(15px); max-width: 400px; width: 100%;">
        <div class="text-center mb-4">
            <h1 class="fw-bold">ShopIQ</h1>
            
        </div>

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <input asp-for="Email" class="form-control form-control-lg" placeholder="Email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold" style="background: linear-gradient(135deg,#6366f1,#7c3aed); border: none;">
                Login
            </button>
        </form>

        <div class="text-center mt-3 small">
            Don't have an account? <a asp-action="Register" asp-controller="Account" class="text-decoration-underline">Register</a>
        </div>

        <div class="text-center mt-1 small">
            Forgot password? <a asp-action="ForgotPassword" asp-controller="Account" class="text-decoration-underline">Reset</a>
        </div>
    </div>

</body>
</html>
