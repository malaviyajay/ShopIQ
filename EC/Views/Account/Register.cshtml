@model EC.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register · EC</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        :root {
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --bg-body: #f1f5f9;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg-body);
            margin: 0;
        }

        .auth-card {
            width: 900px;
            max-width: 90%;
            min-height: 600px;
            display: flex;
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            position: relative;
        }

        .form-side {
            flex: 1;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .brand-logo {
            font-size: 2rem;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 2rem;
            text-decoration: none;
        }

        .form-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .form-subtitle {
            color: var(--text-muted);
            margin-bottom: 2rem;
            font-size: 0.95rem;
        }

        .form-control {
            height: 50px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                background: #fff;
                border-color: var(--primary);
                box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
            }

        .btn-primary-custom {
            background-color: var(--primary);
            border: none;
            height: 50px;
            border-radius: 12px;
            font-weight: 600;
            width: 100%;
            color: white;
            transition: all 0.3s ease;
        }

            .btn-primary-custom:hover {
                background-color: var(--primary-hover);
                transform: translateY(-2px);
                box-shadow: 0 10px 20px -5px rgba(79, 70, 229, 0.3);
                color: white;
            }

        .visual-side {
            flex: 1;
            background: linear-gradient(135deg, #4f46e5, #818cf8);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 40px;
            overflow: hidden;
        }

        .circle {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(5px);
        }

        .c1 {
            width: 300px;
            height: 300px;
            top: -50px;
            right: -50px;
            animation: float 6s infinite;
        }

        .c2 {
            width: 200px;
            height: 200px;
            bottom: 50px;
            left: -50px;
            animation: float 8s infinite reverse;
        }
        @@keyframes float {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(20px);
            }
        }
        @@media (max-width: 992px) {
            .visual-side {
                display: none;
            }

            .auth-card {
                max-width: 500px;
            }
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="form-side">
            <a href="/" class="brand-logo">EC.</a>
            <h1 class="form-title">Create Account</h1>
            <p class="form-subtitle">Join us to start your journey.</p>

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 ps-3" style="border-radius: 12px 0 0 12px; border-color: #e2e8f0;">
                            <i class="bi bi-person text-muted"></i>
                        </span>
                        <input asp-for="Name" class="form-control border-start-0 ps-0" placeholder="John Doe" style="border-radius: 0 12px 12px 0;" />
                    </div>
                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone Number</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 ps-3"style="border-radius:12px 0 0 12px; border-color:#e2e8f0;">
                            <i class="bi bi-telephone text-muted"></i>
                        </span>

                        <input asp-for="Phone"class="form-control border-start-0 ps-0"placeholder="9876543210"style="border-radius:0 12px 12px 0;" />
                    </div>

                    <span asp-validation-for="Phone"
                          class="text-danger small mt-1 d-block">
                      </span>
                </div>
                <div class="mb-4">
                    <label class="form-label">Address</label>

                    <textarea asp-for="Address"class="form-control"rows="3"placeholder="Enter your address"></textarea>

                    <span asp-validation-for="Address"
                          class="text-danger small mt-1 d-block">
                      </span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 ps-3" style="border-radius: 12px 0 0 12px; border-color: #e2e8f0;">
                            <i class="bi bi-envelope text-muted"></i>
                        </span>
                        <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="name@example.com" style="border-radius: 0 12px 12px 0;" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>
              

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 ps-3" style="border-radius: 12px 0 0 12px; border-color: #e2e8f0;">
                            <i class="bi bi-lock text-muted"></i>
                        </span>
                        <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" style="border-radius: 0 12px 12px 0;" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <button class="btn btn-primary-custom" type="submit">Create Account</button>
            </form>

            <div class="mt-4 text-center small text-muted">
                Already have an account? <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Sign In</a>
            </div>
        </div>

        <div class="visual-side">
            <div class="circle c1"></div>
            <div class="circle c2"></div>
            <div class="text-center position-relative">
                <h2 class="fw-bold">Welcome!</h2>
                <p class="opacity-75">Join EC today and manage your account with ease.</p>
            </div>
        </div>
    </div>
</body>
</html>