@model EC.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ShopIQ</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="d-flex justify-content-center align-items-center min-vh-100" style="background: url('/images/bg.jpg') no-repeat center center/cover;">

    <div class="card bg-light bg-opacity-25 shadow-lg p-4 rounded-4" style="max-width: 400px; width: 100%;">
        <div class="text-center mb-4">
            <h2 class="text-white fw-bold">ShopIQ</h2>
        </div>

        <form method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <input asp-for="Name" class="form-control rounded-3" placeholder="Full Name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Phone" class="form-control rounded-3" placeholder="Phone" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <textarea asp-for="Address" class="form-control rounded-3" placeholder="Address" rows="3"></textarea>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Email" class="form-control rounded-3" placeholder="Email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Password" type="password" class="form-control rounded-3" placeholder="Password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 rounded-3 fw-semibold">Create Account</button>
        </form>

        <div class="text-center mt-3 text-white small">
            Already registered? <a asp-action="Login" class="text-decoration-underline text-white">Login</a>
        </div>
    </div>

</body>
</html>
