@model EC.Models.RoleSelectionViewModel

@{
    ViewData["Title"] = "SelectRole";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ShopIQ</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="d-flex justify-content-center align-items-center vh-100"
      style="background: url('/images/bg.jpg') no-repeat center center; background-size: cover; font-family: 'Poppins', sans-serif;">

    <div class="card p-4 p-md-5 shadow-lg rounded-4 bg-white bg-opacity-25 border border-light border-opacity-25 text-white" style="backdrop-filter: blur(15px); max-width: 400px; width: 100%;">
        <div class="text-center mb-4">
            <h1 class="fw-bold">ShopIQ</h1>
        </div>

        <div class="text-center mb-4">
            <h3 class="fw-bold">Select a role</h3>
        </div>

        <form method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <select asp-for="SelectedRole" asp-items="@Model.Roles" class="form-select form-select-lg mb-3" aria-label="Large select example">
                    <option value="">--Select a Role--</option>
                </select>
                <span asp-validation-for="SelectedRole" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg fw-bold" style="background: linear-gradient(135deg,#6366f1,#7c3aed); border: none;">
                Proceed
            </button>
        </form>

    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }

</body>
</html>