   @model List<EC.Models.Product>

@{
    ViewBag.Title = "Your Cart";
    decimal grandTotal = Model.Sum(x => x.Price * x.Quantity);
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary-color: #007185;
        --secondary-color: #f7ca00;
        --secondary-hover: #e0b700;
        --text-main: #0F1111;
        --text-muted: #565959;
        --bg-light: #f3f3f3;
        --white: #ffffff;
        --danger: #CC0C39;
        --border-color: #e7e7e7;
    }

    body {
        background-color: var(--bg-light);
        font-family: "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: var(--text-main);
        margin: 0;
    }

    /* ===== CART WRAPPER ===== */
    .cart-wrapper {
        background: var(--white);
        border-radius: 12px;
        padding: 25px 30px;
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }

    .cart-title {
        font-weight: 700;
        font-size: 1.75rem;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-main);
    }

    /* ===== TABLE STYLES ===== */
    .cart-table th {
        background: transparent;
        font-weight: 600;
        color: var(--text-muted);
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 10px;
    }

    .cart-table td {
        vertical-align: middle;
        padding: 20px 10px;
        border-bottom: 1px solid var(--border-color);
    }

    .product-cell {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .cart-product-img {
        width: 80px;
        height: 80px;
        object-fit: contain;
        border-radius: 8px;
        background: var(--white);
        border: 1px solid var(--border-color);
        padding: 5px;
    }

    .product-name-link {
        font-weight: 600;
        color: var(--text-main);
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 0.2s;
    }

        .product-name-link:hover {
            color: var(--primary-color);
            text-decoration: underline;
        }

    /* ===== QUANTITY CONTROLS ===== */
    .qty-control-group {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--white);
        border: 1px solid #d5d9d9;
        border-radius: 8px;
        padding: 4px;
        width: fit-content;
        box-shadow: 0 2px 5px rgba(213,217,217,0.3);
    }

    .qty-btn {
        background: transparent;
        border: none;
        border-radius: 6px;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-main);
        transition: background 0.2s;
    }

        .qty-btn:hover {
            background: var(--bg-light);
            color: var(--primary-color);
        }

    .qty-value {
        font-weight: 700;
        min-width: 20px;
        text-align: center;
    }

    /* ===== ACTION BUTTONS ===== */
    .remove-btn {
        background: transparent;
        border: none;
        color: var(--danger);
        font-weight: 500;
        font-size: 0.9rem;
        transition: color 0.2s;
        padding: 5px 10px;
        border-radius: 6px;
    }

        .remove-btn:hover {
            background: #fdf3f5;
            text-decoration: underline;
        }

    .back-btn {
        background: transparent;
        border: 1px solid var(--border-color);
        border-radius: 50px;
        color: var(--text-main);
        font-weight: 600;
        padding: 10px 25px;
        display: inline-block;
        text-decoration: none;
        transition: all 0.2s;
    }

        .back-btn:hover {
            background: var(--bg-light);
            border-color: #d1d1d1;
            color: var(--text-main);
        }

    /* ===== RIGHT SUMMARY BOX ===== */
    .summary-box {
        background: var(--white);
        border-radius: 12px;
        padding: 25px;
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        position: sticky;
        top: 20px;
    }

    .checkout-btn {
        background: var(--secondary-color);
        border: 1px solid transparent;
        color: var(--text-main);
        font-weight: 600;
        border-radius: 50px;
        padding: 12px;
        transition: all 0.2s;
        box-shadow: 0 2px 5px rgba(213,217,217,0.5);
    }

        .checkout-btn:hover {
            background: var(--secondary-hover);
            transform: translateY(-1px);
        }

    .price-display {
        font-weight: 700;
        font-size: 1.1rem;
    }

</style>

<div class="container mt-4 mb-5">
    <div class="row g-4">

        <div class="col-lg-8">
            <div class="cart-wrapper">
                <h2 class="cart-title"><i class="fas fa-shopping-cart text-primary me-2"></i> Shopping Cart</h2>

                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-cart-arrow-down fa-4x text-muted mb-3" style="opacity: 0.5;"></i>
                        <h4 class="fw-bold">Your EC cart is empty</h4>
                        <p class="text-muted mb-4">Check out today's deals or continue shopping to find what you need.</p>
                        <a href="@Url.Action("Index", "Product")" class="checkout-btn px-4 text-decoration-none d-inline-block">
                            Start Shopping
                        </a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table cart-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th style="min-width: 250px;">Product</th>
                                    <th>Price</th>
                                    <th style="width: 140px;">Quantity</th>
                                    <th class="text-end">Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="product-cell">
                                                <img src="@Url.Content("~/images/products/" + p.Image)"
                                                     alt="@p.Name"
                                                     class="cart-product-img"
                                                     onerror="this.src='https://via.placeholder.com/80?text=Img'" />
                                                <div>
                                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id" class="product-name-link">
                                                        @p.Name
                                                    </a>
                                                    <div class="text-success small fw-bold mt-1">In Stock</div>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="fw-semibold">₹@p.Price</td>

                                        <td>
                                            <div class="qty-control-group">
                                                <form asp-action="DecreaseQty" method="post" class="m-0 p-0 d-flex">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@p.Id" />
                                                    <button class="qty-btn" title="Decrease Quantity"><i class="fas fa-minus small"></i></button>
                                                </form>

                                                <span class="qty-value">@p.Quantity</span>

                                                <form asp-action="IncreaseQty" method="post" class="m-0 p-0 d-flex">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@p.Id" />
                                                    <button class="qty-btn" title="Increase Quantity"><i class="fas fa-plus small"></i></button>
                                                </form>
                                            </div>
                                        </td>

                                        <td class="text-end price-display">
                                            ₹@(p.Price* p.Quantity)
                                        </td>

                                        <td class="text-end">
                                            <form asp-action="RemoveFromCart" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@p.Id" />
                                                <button class="remove-btn" title="Remove from cart">
                                                    <i class="fas fa-trash-alt me-1"></i> Delete
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (Model.Any())
                {
                    <div class="mt-4 pt-3 border-top text-end text-lg-start">
                        <a href="@Url.Action("Index", "Product")" class="back-btn">
                            <i class="fas fa-arrow-left me-2"></i> Continue Shopping
                        </a>
                    </div>
                }
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="col-lg-4">
                <div class="summary-box">
                    <h5 class="fw-bold mb-4">Order Summary</h5>

                    <div class="d-flex justify-content-between mb-2 text-muted">
                        <span>Items (@Model.Sum(x => x.Quantity)):</span>
                        <span>₹@grandTotal</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Delivery:</span>
                        <span class="text-success fw-bold">FREE</span>
                    </div>

                    <hr class="text-muted opacity-25" />

                    <div class="d-flex justify-content-between fw-bold fs-4 mb-4" style="color: var(--danger);">
                        <span>Order Total:</span>
                        <span>₹@grandTotal</span>
                    </div>

                    <a asp-controller="Checkout"
                       asp-action="Index"
                       class="btn checkout-btn w-100 d-block text-center text-decoration-none">
                        Proceed to Buy
                    </a>

                    <div class="text-center mt-3 small text-muted">
                        <i class="fas fa-shield-alt text-primary me-1"></i> Safe and secure payments.
                    </div>
                </div>
            </div>
        }

    </div>
</div>