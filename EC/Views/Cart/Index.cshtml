@model List<EC.Models.Product>

@{
    ViewBag.Title = "Your Cart";
    decimal grandTotal = Model.Sum(x => x.Price * x.Quantity);
}

<div class="container mt-5">
    <h2>🛒 Your Shopping Cart</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            Your cart is empty.
        </div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Name</td>
                        <td>₹@p.Price</td>
                        <td>
                            <form asp-action="DecreaseQty" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Id" />
                                <button class="btn btn-outline-secondary btn-sm">−</button>
                            </form>
                            <span class="mx-2">@p.Quantity</span>
                            <form asp-action="IncreaseQty" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Id" />
                                <button class="btn btn-outline-secondary btn-sm">+</button>
                            </form>
                        </td>
                        <td>₹@(p.Price* p.Quantity)</td>
                        <td>
                            <form asp-action="RemoveFromCart" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Id" />
                                <button class="btn btn-danger btn-sm">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-4 text-end">
            <h4>Total: ₹@grandTotal</h4>
            <a asp-controller="Checkout" asp-action="Index" class="btn btn-success">Proceed to Checkout</a>
        </div>
    }
    <!-- 🔙 Back Button -->
    <div class="mb-3">
        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
            ← Back to Home
        </a>
    </div>
</div>
