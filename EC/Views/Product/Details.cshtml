@model EC.Models.Product

@{
    ViewBag.Title = Model.Name;
}

<style>
    .product-details-card {
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .product-image {
        width: 100%;
        height: 350px;
        object-fit: cover;
        background: #f8f9fa;
    }

    .price-box {
        font-size: 1.6rem;
        font-weight: 700;
        color: #198754;
    }

    .old-price {
        text-decoration: line-through;
        color: #6c757d;
        font-size: 1rem;
        margin-left: 10px;
    }

    .category-badge {
        background: #e9ecef;
        color: #495057;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        display: inline-block;
    }

    .buy-btn {
        border-radius: 30px;
        padding: 12px 25px;
        font-size: 1.05rem;
    }
</style>

<div class="container mt-5">
    <div class="product-details-card">

        <div class="row g-0">

            <!-- 🖼 PRODUCT IMAGE -->
            <img src="@($"/images/products/{Model.Image}")"
                 class="product-img"
                 alt="@Model.Name" />


            

            <!-- 📄 PRODUCT INFO -->
            <div class="col-md-7 p-4">

                <h2 class="mb-2">@Model.Name</h2>

                <span class="category-badge mb-3">
                    @Model.CategoryName
                </span>

                <div class="my-3">
                    @{
                        var discount = 15;
                        var oldPrice = Model.Price + (Model.Price * discount / 100);
                    }

                    <span class="price-box">₹@Model.Price</span>
                    <span class="old-price">₹@oldPrice</span>
                </div>

                <p class="text-muted">
                    High quality product with best price.
                    7-day replacement • Secure payment • Fast delivery
                </p>

                <div class="mt-4 d-flex gap-3">
                    <a asp-controller="Cart"
                       asp-action="AddToCart"
                       asp-route-id="@Model.Id"
                       class="btn btn-success buy-btn">
                        🛒 Add to Cart
                    </a>

                    <a asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-outline-secondary buy-btn">
                        Continue Shopping
                    </a>
                </div>

            </div>

        </div>
    </div>
</div>
