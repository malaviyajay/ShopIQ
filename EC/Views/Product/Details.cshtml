@model EC.Models.Product
@using EC.Data
@inject DbHelper _db

@{
    ViewBag.Title = Model.Name;
    double avg = ViewBag.AvgRating ?? 0;
    int total = ViewBag.TotalRatings ?? 0;
    var discount = 15;
    var oldPrice = Model.Price + (Model.Price * discount / 100);
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    .product-wrapper { display: flex; gap: 30px; background: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);}
    .product-image { width: 100%; object-fit: contain; max-height: 450px; }
    .product-title { font-size: 1.8rem; font-weight: 600; margin-bottom: 10px; }
    .rating-stars, .avg-stars { display: flex; gap: 5px; font-size: 1.4rem; cursor: pointer; }
    .rating-stars i, .avg-stars i { color: #ccc; transition: color 0.2s; }
    .rating-stars i.selected, .rating-stars i.hovered, .avg-stars i.active { color: #f08804; }
    .comment-box { margin-top: 15px; display: none; }
    .comment-box textarea { width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #ccc; resize: none; }
    .btn-submit { margin-top: 10px; padding: 10px 20px; border-radius: 6px; background-color: #007185; color: #fff; border: none; cursor: pointer; }
    .review-list { margin-top: 30px; }
    .review-item { border-top: 1px solid #e7e7e7; padding: 10px 0; }
    .review-item:first-child { border-top: none; }
    .review-item .stars { color: #f08804; font-size: 1rem; }
    .price-current { font-size: 1.8rem; font-weight: 700; margin-bottom: 5px; }
    .price-old { color: #565959; text-decoration: line-through; margin-bottom: 10px; display: block; }
</style>

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-lg-5">
            <img src="@(string.IsNullOrEmpty(Model.Image) ? Url.Content("~/images/green.jfif") : Url.Content("~/images/" + Model.Image))" 
                 class="product-image" alt="@Model.Name" 
                 onerror="this.src='@Url.Content("~/images/green.jfif")'" />
        </div>

        <div class="col-lg-4">
            <h1 class="product-title">@Model.Name</h1>

            <!-- Average Rating -->
            <div class="avg-stars mb-2">
                @{
                    int fullStars = (int)avg;
                    bool halfStar = (avg - fullStars) >= 0.5;
                }
                @for(int i=0;i<fullStars;i++){ <i class="fas fa-star active"></i> }
                @if(halfStar){ <i class="fas fa-star-half-alt active"></i> }
                @for(int i=fullStars+(halfStar?1:0);i<5;i++){ <i class="far fa-star"></i> }
                <span class="text-muted small">(@total reviews)</span>
            </div>

            <!-- User Rating -->
            <h5>Rate this product:</h5>
            <div class="rating-stars" id="userRatingStars">
                @for(int i=1;i<=5;i++){
                    <i class="far fa-star" data-value="@i"></i>
                }
            </div>

            <div class="comment-box" id="commentBox">
                <form asp-action="SubmitRating" method="post">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <input type="hidden" name="rating" id="selectedRating" value="0" />
                    <textarea name="comment" placeholder="Write your comment..." rows="3" required></textarea>
                    <button type="submit" class="btn-submit">Submit Review</button>
                </form>
            </div>

            <!-- Price -->
            <div class="mt-3">
                <div class="price-current">₹@Model.Price</div>
                <div class="price-old">M.R.P.: ₹@oldPrice</div>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="buy-box">
                @if(Model.Quantity>0){
                    <label>Quantity:</label>
                    <input type="number" value="1" min="1" max="@Model.Quantity" class="form-control mb-3" />
                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.Id" class="btn btn-warning w-100 mb-3">Add to Cart</a>
                } else {
                    <button class="btn btn-secondary w-100 mb-3" disabled>Out of Stock</button>
                }
                <button type="button" class="btn btn-outline-secondary w-100" onclick="history.back();">Back to Products</button>
            </div>
        </div>
    </div>

<!-- Reviews List -->
<div class="review-list">
    <h4>Customer Reviews</h4>
    @if(ViewBag.Reviews != null && ((IEnumerable<EC.Models.Review>)ViewBag.Reviews).Any())
    {
        foreach(var r in (IEnumerable<EC.Models.Review>)ViewBag.Reviews)
        {
            <div class="review-item">
                <div class="stars">
                    @for(int i=0;i<r.Rating;i++){ <i class="fas fa-star"></i> }
                    @for(int i=r.Rating;i<5;i++){ <i class="far fa-star"></i> }
                </div>
                <p>@r.Comment</p>
                <small class="text-muted">by @(r.User?.Name ?? "Anonymous")</small>
            </div>
        }
    }
    else
    {
        <p>No reviews yet.</p>
    }
</div></div>

<style>
    .rating-stars i { color: #ccc; cursor: pointer; font-size: 1.5rem; transition: color 0.2s; }
    .rating-stars i.hovered, .rating-stars i.selected { color: #f08804; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const stars = document.querySelectorAll('#userRatingStars i');
        const commentBox = document.getElementById('commentBox');
        const selectedRatingInput = document.getElementById('selectedRating');

        function updateStars(upTo) {
            stars.forEach((star, idx) => {
                if (idx < upTo) star.classList.add('selected');
                else star.classList.remove('selected');
            });
        }

        stars.forEach(star => {
            star.addEventListener('mouseover', () => {
                const val = parseInt(star.dataset.value);
                stars.forEach((s, idx) => {
                    if(idx < val) s.classList.add('hovered');
                    else s.classList.remove('hovered');
                });
            });

            star.addEventListener('mouseout', () => {
                stars.forEach(s => s.classList.remove('hovered'));
                updateStars(parseInt(selectedRatingInput.value));
            });

            star.addEventListener('click', () => {
                const val = parseInt(star.dataset.value);
                selectedRatingInput.value = val;
                updateStars(val);
                commentBox.style.display = 'block';
            });
        });

        updateStars(parseInt(selectedRatingInput.value));
    });
</script>