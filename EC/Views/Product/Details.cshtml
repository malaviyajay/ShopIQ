@model EC.Models.Product
@using EC.Data
@inject DbHelper _db

@{
    ViewBag.Title = Model.Name;
    double avg = ViewBag.AvgRating ?? 0;
    int total = ViewBag.TotalRatings ?? 0;
    var discount = 15;
    var oldPrice = Model.Price + (Model.Price * discount / 100);
    int reviewPageSize = 5; 
    var reviews = ((IEnumerable<EC.Models.Review>)ViewBag.Reviews).Take(reviewPageSize).ToList();
    int totalReviews = ((IEnumerable<EC.Models.Review>)ViewBag.Reviews).Count();
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --primary-color: #007185;
        --secondary-color: #ffd814;
        --secondary-hover: #f7ca00;
        --accent-color: #ffa41c;
        --text-dark: #0f1111;
        --text-muted: #565959;
        --bg-light: #fff;
        --border-color: #d5d9d9;
    }

    body { 
        font-family: 'Inter', sans-serif; 
        background-color: var(--bg-light); 
        color: var(--text-dark); 
        line-height: 1.5;
    }

    /* Layout & Spacing */
    .product-details-wrapper { padding-top: 20px; }
    
    /* Image Gallery */
    .main-img-container { 
        background: #fff; 
        padding: 20px; 
        height: 450px; 
        display: flex; 
        align-items: center; 
        justify-content: center;
    }
    .main-img-container img { max-height: 100%; max-width: 100%; object-fit: contain; }
    
    .thumbnail-track { display: flex; gap: 10px; margin-top: 15px; justify-content: center; }
    .thumb { 
        width: 50px; height: 50px; border-radius: 4px; cursor: pointer; 
        border: 1px solid var(--border-color); object-fit: contain; padding: 2px;
    }
    .thumb.active { border: 2px solid var(--accent-color); box-shadow: 0 0 3px rgba(255,164,28,0.5); }

    /* Product Titles & Ratings */
    .product-title { font-size: 24px; font-weight: 700; color: var(--text-dark); margin-bottom: 5px; }
    .brand-link { color: var(--primary-color); text-decoration: none; font-size: 14px; font-weight: 500; }
    .brand-link:hover { color: #c45500; text-decoration: underline; }

    .rating-badge-text { color: var(--primary-color); font-size: 14px; text-decoration: none; }
    .rating-badge-text:hover { color: #c45500; text-decoration: underline; }
    .star-active { color: var(--accent-color); }

    /* Pricing */
    .price-container { border-top: 1px solid #eee; border-bottom: 1px solid #eee; padding: 15px 0; margin: 15px 0; }
    .price-tag { font-size: 28px; font-weight: 500; }
    .discount-pct { color: #CC0C39; font-size: 28px; font-weight: 300; }
    .price-old { color: var(--text-muted); font-size: 14px; text-decoration: line-through; }

    /* Buy Box (Sticky Right Side) */
    .buy-box { 
        border: 1px solid var(--border-color); 
        border-radius: 8px; 
        padding: 20px; 
        background: #fff; 
        position: sticky; 
        top: 20px;
    }

    /* Buttons - Amazon Authentic Style */
    .btn-amazon-primary {
        background: var(--secondary-color);
        border: 1px solid #f2c200;
        border-radius: 20px;
        color: #0f1111;
        font-weight: 500;
        padding: 8px 15px;
        width: 100%;
        font-size: 14px;
        transition: 0.2s;
        box-shadow: 0 2px 5px rgba(213,217,217,0.5);
    }
    .btn-amazon-primary:hover { background: var(--secondary-hover); border-color: #e2b400; }

    .btn-amazon-secondary {
        background: var(--accent-color);
        border: 1px solid #ee9311;
        border-radius: 20px;
        color: #0f1111;
        font-weight: 500;
        padding: 8px 15px;
        width: 100%;
        font-size: 14px;
        box-shadow: 0 2px 5px rgba(213,217,217,0.5);
    }

    .back-btn {
        color: var(--primary-color);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        margin-bottom: 15px;
    }
    .back-btn:hover { color: #c45500; text-decoration: underline; }

    /* Reviews Section */
    .review-card { border-top: 1px solid #eee; padding: 20px 0; }
    .avatar-circle { width: 34px; height: 34px; background: #e9ecef; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; }
    
    .progress { height: 20px; border-radius: 4px; background-color: #f0f2f2; border: 1px solid #ccc; }
    .progress-bar { background-color: var(--accent-color); }

    .comment-area { 
        border: 1px solid var(--border-color); 
        border-radius: 4px; 
        padding: 10px; 
        font-size: 14px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1) inset;
    }
</style>

<div class="container product-details-wrapper">
    <a asp-controller="Product" asp-action="Index" class="back-btn">
        <i class="fas fa-chevron-left me-2" style="font-size: 10px;"></i> Back to results
    </a>

    <div class="row g-4">
        <div class="col-lg-5 text-center">
            <div class="main-img-container">
                <img id="mainImage" src="@(string.IsNullOrEmpty(Model.Image) ? Url.Content("~/images/default.jpg") : Url.Content("~/images/" + Model.Image))" />
            </div>
            <div class="thumbnail-track">
                <img src="@(string.IsNullOrEmpty(Model.Image) ? Url.Content("~/images/default.jpg") : Url.Content("~/images/" + Model.Image))" class="thumb active" onclick="updateGallery(this)">
            </div>
        </div>

        <div class="col-lg-4">
            <a href="#" class="brand-link small uppercase">Visit the Store</a>
            <h1 class="product-title">@Model.Name</h1>
            
            <div class="d-flex align-items-center gap-2 mb-2">
                <div class="text-warning small">
                    @for(int i=1; i<=5; i++) { <i class="@(i <= avg ? "fas" : "far") fa-star star-active"></i> }
                </div>
                <a href="#reviews" class="rating-badge-text">@total ratings</a>
            </div>

            <div class="price-container">
                <div class="d-flex align-items-center gap-2">
                    <span class="discount-pct">-@discount%</span>
                    <span class="price-tag"><span class="fs-6 align-top mt-2">₹</span>@Model.Price</span>
                </div>
                <div class="price-old">M.R.P.: <span>₹@oldPrice</span></div>
                <div class="text-muted small mt-2">Inclusive of all taxes</div>
            </div>

            <div class="description">
                <h6 class="fw-bold mb-2 fs-6">About this item</h6>
                <ul class="text-dark small ps-3">
                    <li class="mb-1">High-performance specifications for professional use.</li>
                    <li class="mb-1">Sleek, ergonomic design with premium finish.</li>
                    <li class="mb-1">Compatible with all standard industry accessories.</li>
                </ul>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="buy-box">
                <div class="price-tag mb-2" style="font-size: 24px;"><span class="fs-6 align-top">₹</span>@Model.Price</div>
                <div class="text-muted small mb-3">FREE delivery <b>Tomorrow</b>. Order within <span class="text-success">10 hrs 2 mins</span>.</div>

                @if(Model.Quantity > 0) {
                    <h5 class="text-success fs-6 fw-bold mb-3">In Stock</h5>
                    <div class="mb-3">
                        <select class="form-select form-select-sm bg-light" style="width: 80px;">
                            @for(int i=1; i<=Math.Min(Model.Quantity, 10); i++) {
                                <option value="@i">Qty: @i</option>
                            }
                        </select>
                    </div>
                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.Id" class="btn btn-amazon-primary mb-2">
                        Add to Cart
                    </a>
                    <button class="btn btn-amazon-secondary mb-3">Buy Now</button>
                    
                    <div class="small text-muted mb-2"><i class="fas fa-lock me-2"></i> Secure transaction</div>
                } else {
                    <h5 class="text-danger fs-6 fw-bold mb-3">Currently Unavailable</h5>
                    <p class="small text-muted">We don't know when or if this item will be back in stock.</p>
                    <button class="btn btn-secondary w-100 rounded-pill" disabled>Notify Me</button>
                }
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-5 border-top" id="reviews">
        <div class="col-lg-4">
            <h4 class="fw-bold fs-5 mb-3">Customer reviews</h4>
            <div class="d-flex align-items-center gap-2 mb-2">
                <div class="text-warning">
                    @for(int i=1; i<=5; i++) { <i class="@(i <= avg ? "fas" : "far") fa-star star-active"></i> }
                </div>
                <span class="fw-bold">@avg.ToString("F1") out of 5</span>
            </div>
            <div class="text-muted small mb-4">@total global ratings</div>

            @for(int i = 5; i >= 1; i--) {
                var counts = ViewBag.StarCounts as Dictionary<int,int> ?? new Dictionary<int,int>();
                int count = counts.ContainsKey(i) ? counts[i] : 0;
                int pct = total > 0 ? (int)((count * 100.0) / total) : 0;

                <div class="d-flex align-items-center mb-2">
                    <a href="#" class="small text-decoration-none text-primary text-nowrap" style="width: 50px;">@i star</a>
                    <div class="progress flex-grow-1 mx-2">
                        <div class="progress-bar" style="width:@pct%"></div>
                    </div>
                    <span class="small text-muted" style="width: 35px;">@pct%</span>
                </div>
            }

            <div class="mt-4 pt-4 border-top">
                <h6 class="fw-bold">Review this product</h6>
                <p class="small">Share your thoughts with other customers</p>
                
                <div class="rating-stars mb-3" id="userRatingStars">
                    @for(int i=1; i<=5; i++){ <i class="far fa-star star-active fs-4" style="cursor:pointer" data-value="@i"></i> }
                </div>
                
                <div id="commentBox" style="display:none;" class="mt-3">
                    <form asp-action="SubmitRating" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="rating" id="selectedRating" value="0" />
                        <textarea name="comment" class="comment-area w-100 mb-2" rows="4" placeholder="What did you like or dislike?"></textarea>
                        <button type="submit" class="btn btn-amazon-primary py-1" style="width: auto;">Submit</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8 ps-lg-5">
            <h5 class="fw-bold fs-5 mb-4">Top reviews from India</h5>
            <div id="reviewContainer">
                @foreach(var r in reviews) {
                    var Name = string.IsNullOrEmpty(r.Name) ? "Amazon Customer" : r.Name;
                    <div class="review-card">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <div class="avatar-circle"><i class="fas fa-user text-secondary"></i></div>
                            <span class="small">@Name</span>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <div class="text-warning small">
                                @for(int i=0; i<r.Rating; i++){ <i class="fas fa-star star-active"></i> }
                                @for(int i=r.Rating; i<5; i++){ <i class="far fa-star star-active"></i> }
                            </div>
                            
                        </div>
                        <div class="text-muted small mb-2">Reviewed on @r.CreatedAt.ToString("dd MMM yyyy")</div>
                        <p class="small mb-0">@r.Comment</p>
                    </div>
                }
            </div>
            
            @if(totalReviews > reviewPageSize) {
                <button id="loadMoreReviews" class="btn btn-outline-secondary btn-sm mt-3 px-4 rounded-pill">See more reviews</button>
            }
        </div>
    </div>
</div>

<script>
    function updateGallery(element) {
        document.getElementById('mainImage').src = element.src;
        document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
        element.classList.add('active');
    }

    document.addEventListener('DOMContentLoaded', function () {
        const stars = document.querySelectorAll('#userRatingStars i');
        const ratingInput = document.getElementById('selectedRating');
        const commentBox = document.getElementById('commentBox');

        stars.forEach(star => {
            star.addEventListener('click', function () {
                let selected = parseInt(this.dataset.value);
                ratingInput.value = selected;
                stars.forEach(s => {
                    s.classList.replace('fas', 'far');
                    if (parseInt(s.dataset.value) <= selected) s.classList.replace('far', 'fas');
                });
                commentBox.style.display = 'block';
            });
        });
    });
</script>