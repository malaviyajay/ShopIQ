@model List<EC.Models.Product>

@{
    ViewData["Title"] = "Products";

    if (!Context.Request.Query.TryGetValue("categoryId", out var categoryString) || !int.TryParse(categoryString, out var categoryID))
    {
        categoryID = 0;
    }
}

<style>
    .page-header {
        background: #232f3e;
        color: #fff;
        padding: 18px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

        .page-header .brand {
            font-size: 1.4rem;
            font-weight: 700;
        }

    .search-box input {
        border-radius: 30px;
        padding-left: 20px;
        height: 45px;
    }

    .category-card {
        border-radius: 16px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .product-card {
        border-radius: 16px;
        transition: all .25s ease;
        position: relative;
        overflow: hidden;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        height: 100%;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.15);
        }

    .product-img {
        height: 210px;
        width: 100%;
        object-fit: cover;
        background: #f8f9fa;
    }

    .price {
        font-size: 1.1rem;
        font-weight: 700;
        color: #198754;
    }

    .old-price {
        font-size: 0.9rem;
        text-decoration: line-through;
        color: #6c757d;
        margin-left: 5px;
    }

    .discount-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #dc3545;
        color: #fff;
        padding: 4px 10px;
        font-size: 12px;
        border-radius: 20px;
    }

    .prime-badge {
        background: #232f3e;
        color: #fff;
        padding: 3px 8px;
        border-radius: 8px;
        font-size: 12px;
        margin-top: 5px;
        display: inline-block;
    }

    .rating {
        color: #ff9900;
        font-size: 12px;
    }

    .btn-rounded {
        border-radius: 30px;
    }
</style>

<div class="container mt-4">
    <div class="row g-4">

        <!-- ================= CATEGORY DROPDOWN ================= -->
        <div class="col-md-3">
            <div class="card category-card p-3">

                <label class="fw-bold mb-2">Select Category</label>

                <select class="form-select" onchange="window.location.href = this.value;">

                    <!-- All Products (Clears filter) -->
                    @if (categoryID <= 0)
                    {
                        <option value='@Url.Action("Index", "Product")' selected>
                            All Products
                        </option>
                    }
                    else
                    {
                        <option value='@Url.Action("Index", "Product")'>
                            All Products
                        </option>
                    }


                    @if (ViewBag.Categories != null)
                    {
                        foreach (var c in ViewBag.Categories)
                        {
                            @if (categoryID == c.Id)
                            {
                                <option value='@Url.Action("Index", "Product", new { categoryId = c.Id })' selected>
                                    @c.Name
                                </option>
                            }
                            else
                            {
                                <option value='@Url.Action("Index", "Product", new { categoryId = c.Id })'>
                                    @c.Name
                                </option>
                            }
                        }
                    }

                </select>
            </div>
        </div>

        <!-- ================= PRODUCTS ================= -->
        <div class="col-md-9">
            <div class="row g-4">

                @if (Model == null || !Model.Any())
                {
                    <div class="col-12">
                        <div class="alert alert-warning text-center">
                            No products available
                        </div>
                    </div>
                }
                else
                {
                    foreach (var p in Model)
                    {
                        var discount = 20;
                        var oldPrice = p.Price + (p.Price * discount / 100);

                        <div class="col-xl-3 col-lg-4 col-md-6">
                            <div class="card product-card p-3 text-center">

                                <span class="discount-badge">@discount% OFF</span>
                                <img src="@Url.Content("~/images/products/" + p.Image)"
                                     class="product-img"
                                     alt="@p.Name" />



                                <h6 class="fw-semibold">@p.Name</h6>

                                <div class="rating">
                                    ⭐⭐⭐⭐ (4.2)
                                </div>

                                <p class="mt-1">
                                    <span class="price">₹@p.Price</span>
                                    <span class="old-price">₹@oldPrice</span>
                                </p>

                                <div class="prime-badge">Prime</div>

                                <div class="d-grid gap-2 mt-2">
                                    <a asp-controller="Cart"
                                       asp-action="AddToCart"
                                       asp-route-id="@p.Id"
                                       class="btn btn-warning btn-sm btn-rounded">
                                        🛒 Add to Cart
                                    </a>

                                    <a asp-controller="Product"
                                       asp-action="Details"
                                       asp-route-id="@p.Id"
                                       class="btn btn-outline-primary btn-sm btn-rounded">
                                        View Details
                                    </a>
                                </div>

                            </div>
                        </div>
                    }
                }

            </div>
        </div>

    </div>
</div>
