@model dynamic 
 

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary-color: #007185;
        --secondary-color: #f7ca00;
        --secondary-hover: #e0b700;
        --text-main: #0F1111;
        --text-muted: #565959;
        --bg-light: #f3f3f3;
        --white: #ffffff;
        --border-color: #e7e7e7;
    }

    body {
        background: var(--bg-light);
        font-family: "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: var(--text-main);
    }

    .profile-bg {
        padding: 40px 0;
        min-height: 80vh;
    }

    /* ===== DASHBOARD CARDS ===== */
    .dashboard-card {
        background: var(--white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        overflow: hidden;
    }

    /* ===== LEFT MENU ===== */
    .menu-card {
        padding: 25px 20px;
        position: sticky;
        top: 20px;
    }

    .menu-card h5 {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 20px;
        color: var(--text-main);
        padding-bottom: 10px;
        border-bottom: 2px solid var(--bg-light);
    }

    .menu-list {
        list-style: none;
        padding: 0;
        margin: 0 0 20px 0;
    }

    .menu-list li {
        margin-bottom: 10px;
    }

    .menu-list a {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 15px;
        border-radius: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s;
    }

    .menu-list a:hover {
        background: var(--bg-light);
        color: var(--primary-color);
    }

    .menu-list a.active {
        background: rgba(0, 113, 133, 0.1);
        color: var(--primary-color);
        font-weight: 600;
        border-left: 4px solid var(--primary-color);
    }

    .btn-edit-profile {
        background: var(--secondary-color);
        border: 1px solid transparent;
        color: var(--text-main);
        font-weight: 600;
        border-radius: 50px;
        padding: 10px;
        text-align: center;
        display: block;
        text-decoration: none;
        transition: all 0.2s;
        box-shadow: 0 2px 5px rgba(213,217,217,0.5);
    }

    .btn-edit-profile:hover {
        background: var(--secondary-hover);
        color: var(--text-main);
        transform: translateY(-1px);
    }

    /* ===== PROFILE HEADER ===== */
    .profile-header {
        background: var(--white);
        border-bottom: 1px solid var(--border-color);
        padding: 30px 25px;
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        background: var(--bg-light);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: var(--primary-color);
        border: 2px solid var(--border-color);
    }

    .profile-header h3 {
        font-weight: 700;
        font-size: 1.75rem;
        margin: 0 0 5px 0;
        color: var(--text-main);
    }

    .profile-header p {
        margin: 0;
        font-size: 0.95rem;
        color: var(--text-muted);
    }

    /* ===== INFO GRID ===== */
    .profile-info {
        padding: 30px 25px;
    }

    .info-box {
        display: flex;
        align-items: flex-start;
        gap: 15px;
        padding: 15px;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        background: var(--bg-light);
        height: 100%;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .info-box:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
        background: var(--white);
    }

    .info-icon {
        background: rgba(0, 113, 133, 0.1);
        color: var(--primary-color);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .info-box h6 {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
        margin: 0 0 5px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-box p {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-main);
        margin: 0;
        word-break: break-word;
    }

    /* ===== BACK BUTTON ===== */
    .btn-back {
        background: transparent;
        border: 1px solid var(--border-color);
        border-radius: 50px;
        color: var(--text-main);
        font-weight: 600;
        padding: 10px 25px;
        margin-top: 25px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .btn-back:hover {
        background: var(--white);
        border-color: #d1d1d1;
    }
</style>

<div class="profile-bg">
    <div class="container">
        
        <div class="row g-4">

            <div class="col-lg-3 col-md-4">
                <div class="dashboard-card menu-card">

                    <h5><i class="fas fa-user-circle text-primary me-2"></i> Your Account</h5>
                    
                    <ul class="menu-list">
                        <li>
                            <a href="#" class="active">
                                <i class="fas fa-id-card"></i> Profile Info
                            </a>
                        </li>
                        <li>
                            @if (User.IsInRole("Customer") && !User.IsInRole("Admin") && !User.IsInRole("Seller"))
                            {
                                <a class="dropdown-item" asp-controller="Order" asp-action="Index">
                                    <i class="fas fa-box-open"></i> Your Orders
                                </a>
                            }
                    </ul>

                    <a asp-controller="Profile"asp-action="Edit"class="btn-edit-profile">
                        <i class="fas fa-user-edit me-1"></i> Edit Profile
                    </a>

                </div>
            </div>

            <div class="col-lg-9 col-md-8">
                <div class="dashboard-card">

                    <div class="profile-header">
                        <div class="profile-avatar">
                            @(string.IsNullOrEmpty(Model.Name) ? "U" : Model.Name.Substring(0, 1).ToUpper())
                        </div>
                        <div>
                            <h3>Hello, @Model.Name</h3>
                            <p>Manage your account settings, addresses, and contact preferences here.</p>
                        </div>
                    </div>

                    <div class="profile-info">
                        <h5 class="fw-bold mb-4 border-bottom pb-2">Personal Information</h5>
                        
                        <div class="row g-4">

                            <div class="col-md-6">
                                <div class="info-box">
                                    <div class="info-icon"><i class="fas fa-user"></i></div>
                                    <div>
                                        <h6>Full Name</h6>
                                        <p>@Model.Name</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-box">
                                    <div class="info-icon"><i class="fas fa-envelope"></i></div>
                                    <div>
                                        <h6>Email Address</h6>
                                        <p>@Model.Email</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-box">
                                    <div class="info-icon"><i class="fas fa-phone-alt"></i></div>
                                    <div>
                                        <h6>Phone Number</h6>
                                        <p>@(string.IsNullOrEmpty(Model.Phone) ? "Not provided" : Model.Phone)</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="info-box">
                                    <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                                    <div>
                                        <h6>Primary Address</h6>
                                        <p>@(string.IsNullOrEmpty(Model.Address) ? "Not provided" : Model.Address)</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <button type="button" class="btn-back" onclick="history.back();">
                    <i class="fas fa-arrow-left"></i> Go Back
                </button>
            </div>
        </div>
    </div>
</div>