@{
    string homeController = "Home";
    string homeAction = "Index";

    if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        homeController = "Admin";
        homeAction = "Dashboard";
    }

    string searchController = (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
        ? "Admin"
        : "Product";
}

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopIQ</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        :root {
            --primary: #4f46e5;
            --secondary: #1e293b;
            --bg-body: #f8fafc;
            --surface: #fff;
            --text-main: #0f172a;
        }

        body {
            background: var(--bg-body);
            font-family: 'Poppins',sans-serif;
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .navbar {
            background: var(--surface);
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            padding: 0.8rem 0;
        }

        .brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--primary) !important;
        }

        .nav-link {
            font-weight: 500;
            color: var(--text-main);
        }

            .nav-link:hover {
                color: var(--primary);
            }

        .nav-icon-link {
            color: var(--secondary);
            font-size: 1.2rem;
            margin-right: 15px;
        }

        main {
            flex: 1;
        }

        .social-footer {
            background: #fff;
            border-top: 1px solid #e2e8f0;
            padding: 3rem 0;
            margin-top: auto;
        }

        .social-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #f1f5f9;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin: 0 5px;
            text-decoration: none;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">

            <a class="navbar-brand brand"
               asp-controller="@homeController"
               asp-action="@homeAction">
                ShopIQ
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">

                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="@homeController"
                           asp-action="@homeAction">
                            Home
                        </a>
                    </li>

                    @if (!User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">
                                Shop
                            </a>
                        </li>
                    }
                </ul>

                <form method="get"
                      asp-controller="@searchController"
                      asp-action="Search"
                      class="d-flex mx-auto"
                      style="max-width:420px; width:100%;">

                    <input name="query"
                           class="form-control me-2"
                           type="search"
                           placeholder="Search products..."
                           required />

                    <button class="btn btn-primary" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </form>

                <div class="d-flex align-items-center">

                    @if (!User.IsInRole("Admin"))
                    {
                        <a asp-controller="Cart"
                           asp-action="Index"
                           class="nav-icon-link text-decoration-none position-relative me-3">
                            <i class="bi bi-bag"></i>
                        </a>
                    }

                    <div class="dropdown">
                        <a href="#"
                           class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark fw-bold"
                           data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle fs-4 me-2 text-primary"></i> Account
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index">My Profile</a></li>
                            <li><a class="dropdown-item" asp-controller="Order" asp-action="Index">My Orders</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a asp-controller="Account"
                                   asp-action="Logout"
                                   class="dropdown-item text-danger">
                                    Logout
                                </a>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <footer class="social-footer">
        <div class="container text-center">
            <a href="https://www.facebook.com" class="social-btn"><i class="bi bi-facebook"></i></a>
            <a href="https://www.instagram.com" class="social-btn"><i class="bi bi-instagram"></i></a>
            <a href="https://www.youtube.com" class="social-btn"><i class="bi bi-youtube"></i></a>
            <p class="text-muted small mt-3">© 2026 All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
