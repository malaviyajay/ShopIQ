@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor;
@inject EC.Data.DbHelper _db;

@{
    string homeController = "Home";
    string homeAction = "Index";
    string searchController = "Product";
    List<UserRole> UserRoles = new();
    int selectedRoleId = 0;

    if (HttpContextAccessor!.HttpContext!.IsLoggedIn())
    {
        if (HttpContextAccessor.HttpContext.IsAdmin())
        {
            homeController = "Admin";
            homeAction = "Dashboard";
            searchController = "Admin";
        }
        else if (HttpContextAccessor.HttpContext.IsSeller())
        {
            homeController = "Seller";
            homeAction = "Index";
            searchController = "Seller";
        }

        var userID = HttpContextAccessor.HttpContext.UserId() ?? 0;
        selectedRoleId = HttpContextAccessor.HttpContext.RoleId() ?? 0;

        UserRoles = _db.GetUserRole(userID) ?? new();
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopIQ</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>

        :root {
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --secondary: #64748b;
            --dark: #0f172a;
            --bg-body: #f8fafc;
            --surface: rgba(255,255,255,0.9);
            --border-color: #e2e8f0;
        }

        body {
            background-color: var(--bg-body);
            background-image: radial-gradient(circle at top right,#e0e7ff 0%,transparent 20%),radial-gradient(circle at bottom left,#f1f5f9 0%,transparent 20%);
            font-family: 'Plus Jakarta Sans',sans-serif;
            color: var(--dark);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            letter-spacing: -0.01em;
        }

        .navbar {
            background: var(--surface);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            padding: .75rem 0;
            transition: .3s;
        }

        .brand {
            font-weight: 800;
            font-size: 1.6rem;
            letter-spacing: -1px;
            background: linear-gradient(135deg,var(--primary),#a855f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .search-container {
            position: relative;
            max-width: 450px;
            width: 100%;
            margin: 0 1.5rem;
        }

        .search-input {
            border-radius: 12px;
            border: 1px solid var(--border-color);
            padding: .6rem 1rem .6rem 2.8rem;
            font-size: .9rem;
            background: #f1f5f9;
        }

            .search-input:focus {
                background: #fff;
                box-shadow: 0 0 0 4px rgba(99,102,241,.1);
                border-color: var(--primary);
            }

        .search-icon-btn {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--secondary);
            border: none;
            background: none;
            pointer-events: none;
        }

        .btn-search-submit {
            position: absolute;
            right: 6px;
            top: 50%;
            transform: translateY(-50%);
            padding: 4px 12px;
            border-radius: 8px;
        }

        .nav-link {
            font-weight: 600;
            font-size: .95rem;
            color: var(--secondary) !important;
            padding: .5rem 1rem !important;
            border-radius: 8px;
        }

            .nav-link:hover {
                color: var(--primary) !important;
                background: rgba(99,102,241,.05);
            }

        .nav-icon-link {
            width: 42px;
            height: 42px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: #f1f5f9;
            color: var(--dark);
            transition: .2s;
        }

            .nav-icon-link:hover {
                background: var(--primary);
                color: #fff !important;
                transform: translateY(-2px);
            }

        .account-toggle {
            background: #f1f5f9;
            padding: 6px 14px;
            border-radius: 12px;
            border: 1px solid transparent;
        }

            .account-toggle:hover {
                background: #fff;
                border-color: var(--border-color);
            }

        .dropdown-menu {
            border: none;
            box-shadow: 0 10px 25px rgba(0,0,0,.1);
            border-radius: 14px;
            padding: .75rem;
            margin-top: 10px !important;
        }

        .dropdown-item {
            border-radius: 8px;
            padding: .6rem 1rem;
            font-weight: 500;
        }

        main {
            flex: 1;
            padding-bottom: 4rem;
        }

        .social-footer {
            background: var(--dark);
            color: #fff;
            padding: 4rem 0 2rem 0;
            border-top-left-radius: 40px;
            border-top-right-radius: 40px;
        }

        .social-btn {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            background: rgba(255,255,255,.05);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin: 0 8px;
            color: #fff;
            text-decoration: none;
            font-size: 1.2rem;
            border: 1px solid rgba(255,255,255,.1);
        }

            .social-btn:hover {
                background: var(--primary);
                transform: translateY(-5px);
                color: #fff;
                border-color: var(--primary);
            }

        .footer-divider {
            height: 1px;
            background: rgba(255,255,255,.1);
            margin: 2rem 0;
        }

    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">

            <a class="navbar-brand brand" asp-controller="@homeController" asp-action="@homeAction">
                ShopIQ
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <i class="bi bi-grid-fill text-primary"></i>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">

                <ul class="navbar-nav me-3">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="@homeController" asp-action="@homeAction">Home</a>
                    </li>

                    @if (User.Identity!.IsAuthenticated && User.IsInRole("Customer"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Explore Shop</a>
                        </li>
                    }

                </ul>

                <form method="get" asp-controller="@searchController" asp-action="Search"
                      class="search-container flex-grow-1 d-none d-lg-block">

                    <i class="bi bi-search search-icon-btn"></i>

                    <input name="query" class="form-control search-input shadow-none"
                           type="search" placeholder="What are you looking for?" required />

                    <button class="btn btn-primary btn-sm btn-search-submit" type="submit">
                        Go
                    </button>

                </form>

                <div class="d-flex align-items-center gap-3 ms-auto">

                    @if (User.Identity!.IsAuthenticated && User.IsInRole("Customer"))
                    {
                        <a asp-controller="Cart" asp-action="Index"
                           class="nav-icon-link text-decoration-none position-relative">

                            <i class="bi bi-handbag-fill fs-5"></i>

                            <span id="cartCount"
                                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                0
                            </span>

                        </a>
                    }

                    <div class="dropdown">

                        <a href="#"
                           class="d-flex align-items-center text-decoration-none dropdown-toggle account-toggle text-dark fw-semibold"
                           data-bs-toggle="dropdown">

                            <i class="bi bi-person-circle fs-5 me-2 text-primary"></i>
                            <span class="d-none d-sm-inline">Account</span>

                        </a>

                        <ul class="dropdown-menu dropdown-menu-end shadow">

                            <li>
                                <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-person me-2"></i> My Profile
                                </a>
                            </li>

                            @if (User.Identity.IsAuthenticated && User.IsInRole("Customer"))
                            {
                                <li>
                                    <a class="dropdown-item" asp-controller="Order" asp-action="Index">
                                        <i class="bi bi-box-seam me-2"></i> My Orders
                                    </a>
                                </li>
                            }

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a asp-controller="Account" asp-action="Logout"
                                   class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                                </a>
                            </li>

                        </ul>

                    </div>

                    @if (UserRoles.Any() && UserRoles.Count > 1)
                    {
                        <div class="dropdown">

                            <a href="#"
                               class="d-flex align-items-center text-decoration-none dropdown-toggle account-toggle text-dark fw-semibold"
                               data-bs-toggle="dropdown">

                                <i class="bi bi-person-circle fs-5 me-2 text-primary"></i>
                                <span class="d-none d-sm-inline">Switch Role</span>

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow">

                                @foreach (var item in UserRoles)
                                {
                                    @if (item.RoleId == selectedRoleId)
                                    {
                                        <li>
                                            <a class="dropdown-item bg-body-secondary" href="javascript:void(0);">
                                                <i class="bi bi-person me-2"></i> @item.Name
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Role"
                                               asp-action="ChangeRole"
                                               asp-route-roleId="@item.RoleId">
                                                <i class="bi bi-person me-2"></i> @item.Name
                                            </a>
                                        </li>
                                    }
                                }

                            </ul>
                        </div>
                    }

                </div>
            </div>
        </div>
    </nav>

    <main class="container mt-4 pt-2">
        @RenderBody()
    </main>

    <footer class="social-footer">

        <div class="container text-center">

            <div class="mb-4">
                <h4 class="fw-bold mb-1">ShopIQ</h4>
                <p class="text-secondary small">
                    Your intelligent shopping companion.
                </p>
            </div>

            <div class="d-flex justify-content-center">

                <a href="https://www.facebook.com" class="social-btn">
                    <i class="bi bi-facebook"></i>
                </a>

                <a href="https://www.instagram.com" class="social-btn">
                    <i class="bi bi-instagram"></i>
                </a>

                <a href="https://www.youtube.com" class="social-btn">
                    <i class="bi bi-youtube"></i>
                </a>

                <a href="#" class="social-btn">
                    <i class="bi bi-twitter-x"></i>
                </a>

            </div>

            <div class="footer-divider"></div>

            <p class="text-secondary small mb-0">
                <b>&copy; 2026 ShopIQ Inc. All rights reserved.</b>
            </p>

        </div>

    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        function loadCartCount(){

        const cart=document.getElementById("cartCount");
        if(!cart)return;

        fetch('/Cart/CartCount')
        .then(response=>response.text())
        .then(data=>{
        cart.innerText=data;
        });

        }

        loadCartCount();

    </script>

</body>
</html>